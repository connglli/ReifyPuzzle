// EXPECT: PASS
// Intention: Typechecker accepts bitwise operations on float vectors (exposing known bug, expecting PASS)

fun @main() : i32 {

  let mut %loop_idx: i32 = 0;
  let %two: i32 = 2;
  let mut %v_val: <4> i32 = {1, 2, 3, 4};
  let mut %f_val: <4> f32 = {1.0, 2.0, 3.0, 4.0};
  let mut %cond: i1 = 0;
  let mut %cond2: i1 = 0;
  let mut %early_cond: i1 = 0;
  let %one_i32: i32 = 1;
  let %two_i32: i32 = 2;
  let %three_i32: i32 = 3;
  let %four_i32: i32 = 4;
  let %zero_i32: i32 = 0;
  let %one_f32: f32 = 1.0;
  let %two_f32: f32 = 2.0;
  let %three_f32: f32 = 3.0;
  let %four_f32: f32 = 4.0;
  let %zero_f32: f32 = 0.0;
  let mut %x: <4> f32 = 0.0;
  let %y: <4> f32 = 1.0;

^entry:
  %x[0] = 1.0;
  %f_val[0] = 1.0;
  %f_val[1] = 2.0;
  br ^loop_cond;

^loop_cond:
  %cond = cmp < %loop_idx, %two;
  %early_cond = cmp < %one_f32, %zero_f32;
  %f_val[2] = 3.0;
  br %cond != 0, ^body1, ^exit;

^body1:
  %x = %x & %y; // Type error: bitwise & on float vector
  %f_val[3] = 4.0;
  %f_val[0] = 5.0;
  br ^body2;

^body2:
  %f_val[1] = 6.0;
  %f_val[2] = 7.0;
  %f_val[3] = 8.0;
  br %early_cond != 0, ^early_exit, ^latch;

^latch:
  %loop_idx = %loop_idx + 1;
  %f_val[0] = 9.0;
  %f_val[1] = 10.0;
  br ^loop_cond;

^early_exit:
  %f_val[2] = 11.0;
  %f_val[3] = 12.0;
  %f_val[0] = 13.0;
  ret 0;

^exit:
  %f_val[1] = 14.0;
  %f_val[2] = 15.0;
  %f_val[3] = 16.0;
  ret 0;
}

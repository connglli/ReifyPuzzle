// EXPECT: FAIL:StaticError
// v0.2.1 §6.8.9 + §6.8.5: one `ptrindex` on a nested-array pointer
// `ptr [2][3] i32` yields `ptr [3] i32` — still an aggregate pointer, so
// `load`ing that intermediate result is a type error (aggregates are not
// loadable). A second `ptrindex` is required to reach a loadable `ptr i32`.
// Distinct from v021_load_aggregate_ptr_typeerror.sir, which loads a
// whole-array `addr` rather than a `ptrindex` result.

fun @main() : i32 {
  let mut %a: [2][3] i32 = {{1, 2, 3}, {4, 5, 6}};
  let mut %ap: ptr [2][3] i32 = null;
  let mut %row: ptr [3] i32 = null;
  let mut %v: i32 = 0;          // scalar LHS so load's pointee check fires
^entry:
  %ap = addr %a;
  %row = ptrindex %ap, 1;       // ptr [2][3] i32 -> ptr [3] i32
  %v = load %row;               // type error: ptr [3] i32 is not loadable
  ret %v;
}

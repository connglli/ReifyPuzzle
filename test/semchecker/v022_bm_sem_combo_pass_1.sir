// EXPECT: PASS
// SPEC v0.2.2 §3.3 §9.6 §12
// INTERP_ARGS: -I test/lib/std/scalar
// Intention: in-module fun + stdlib gcd via link-form decl + intrinsic, 5 blocks, vectors.
intrinsic @abs(%x: i32) : i32;
intrinsic @max(%a: i32, %b: i32) : i32;
decl @gcd(%a: i32, %b: i32) : i32;

fun @util(%v: <4> i32) : i32 {
  let mut %sum: i32 = 0;
^entry:
  %sum = %v[0] + %v[1];
  %sum = %sum + %v[2];
  %sum = %sum + %v[3];
  ret %sum;
}

fun @main() : i32 {
  let mut %a: i32 = -7;
  let mut %g: i32 = 0;
  let mut %m: i32 = 0;
  let mut %abv: i32 = 0;
  let mut %vsum: i32 = 0;
  let mut %v: <4> i32 = {1, 2, 3, 4};
  let mut %final: i32 = 0;
^entry:
  %abv = call @abs(%a);
  %g = call @gcd(%abv, 21);
  %m = call @max(%g, 5);
  br %m > 0, ^b1, ^b2;
^b1:
  %vsum = call @util(%v);
  %final = %vsum + %m;
  br %final >= 0, ^bx, ^by;
^b2:
  %final = %m;
  br %final >= 0, ^bx, ^by;
^bx:
  %final = %final + 1;
  ret %final;
^by:
  %final = 0 - %final;
  ret %final;
}

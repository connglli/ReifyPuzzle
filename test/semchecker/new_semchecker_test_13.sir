// EXPECT: PASS
// Intention: Sorting Network Step with aggregate array pointers

fun @main() : i32 {

  let mut %loop_idx: i32 = 0;
  let %two: i32 = 2;
  let mut %v_val: <4> i32 = {1, 2, 3, 4};
  let mut %f_val: <4> f32 = {1.0, 2.0, 3.0, 4.0};
  let mut %cond: i1 = 0;
  let mut %cond2: i1 = 0;
  let mut %early_cond: i1 = 0;
  let %one_i32: i32 = 1;
  let %two_i32: i32 = 2;
  let %three_i32: i32 = 3;
  let %four_i32: i32 = 4;
  let %zero_i32: i32 = 0;
  let %one_f32: f32 = 1.0;
  let %two_f32: f32 = 2.0;
  let %three_f32: f32 = 3.0;
  let %four_f32: f32 = 4.0;
  let %zero_f32: f32 = 0.0;
  let mut %arr: [8] i32 = {10, 5, 20, 15, 0, 0, 0, 0};
  let mut %p: ptr i32 = null;
  let mut %v: <4> i32 = {0, 0, 0, 0};
  let mut %tmp: i32 = 0;
  let mut %cflag: i1 = 0;
  let mut %v0: i32 = 0;
  let mut %v1: i32 = 0;

^entry:
  %p = addr %arr[0];
  %v_val = 1 * %v;
  %v_val[0] = 1;
  br ^loop_cond;

^loop_cond:
  %cond = cmp < %loop_idx, %two;
  %early_cond = cmp < %one_i32, %zero_i32;
  %v_val = 1 * %v;
  br %cond != 0, ^body1, ^exit;

^body1:
  %v0 = load %p;
  %v[0] = %v0;
  %p = %p + %one_i32;
  br ^body2;

^body2:
  %v1 = load %p;
  %v[1] = %v1;
  %cflag = cmp > %v[0], %v[1];
  br %early_cond != 0, ^early_exit, ^latch;

^latch:
  %loop_idx = %loop_idx + 1;
  %v_val[2] = 3;
  %v_val = 1 * %v;
  br ^loop_cond;

^early_exit:
  %f_val[0] = 1.0;
  %v_val[3] = 4;
  %v_val = 1 * %v;
  ret 0;

^exit:
  require %v[0] > 0;
  require %v[1] > 0;
  %v_val = 1 * %v_val;
  ret 0;
}

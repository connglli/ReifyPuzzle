// EXPECT: PASS
// SPEC v0.2.2 §3.3 §9.6 §12
// INTERP_ARGS: -I test/lib/std/scalar
// Intention: array indexing + multiple intrinsics + stdlib + 5 blocks.
intrinsic @abs(%x: i32) : i32;
intrinsic @max(%a: i32, %b: i32) : i32;
intrinsic @min(%a: i32, %b: i32) : i32;
decl @gcd(%a: i32, %b: i32) : i32;

fun @sum2(%a: i32, %b: i32) : i32 { ^entry: ret %a + %b; }

fun @main() : i32 {
  let mut %arr: [4] i32 = {-3, 5, 7, -2};
  let mut %i: i32 = 0;
  let mut %a0: i32 = 0;
  let mut %a3: i32 = 0;
  let mut %ab0: i32 = 0;
  let mut %ab3: i32 = 0;
  let mut %mx: i32 = 0;
  let mut %mn: i32 = 0;
  let mut %g: i32 = 0;
  let mut %s: i32 = 0;
  let mut %final: i32 = 0;
^entry:
  %a0 = %arr[0];
  %a3 = %arr[3];
  %ab0 = call @abs(%a0);
  %ab3 = call @abs(%a3);
  br %ab0 > 0, ^b1, ^b2;
^b1:
  %mx = call @max(%ab0, %ab3);
  %mn = call @min(%ab0, %ab3);
  %g = call @gcd(%mx, %mn);
  br %g >= 1, ^b3, ^b4;
^b2:
  %g = 0;
  br %g == 0, ^b3, ^b4;
^b3:
  %s = call @sum2(%g, %mx);
  %final = %s;
  ret %final;
^b4:
  %final = 0 - %g;
  ret %final;
}

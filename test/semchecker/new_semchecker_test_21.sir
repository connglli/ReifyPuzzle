// EXPECT: FAIL:StaticError
// Intention: Semchecker error: duplicate local variable declaration

fun @main() : i32 {

  let mut %loop_idx: i32 = 0;
  let %two: i32 = 2;
  let mut %v_val: <4> i32 = {1, 2, 3, 4};
  let mut %f_val: <4> f32 = {1.0, 2.0, 3.0, 4.0};
  let mut %cond: i1 = 0;
  let mut %cond2: i1 = 0;
  let mut %pre_cond: i1 = 0;
  let mut %post_cond: i1 = 0;
  let %one_i32: i32 = 1;
  let %two_i32: i32 = 2;
  let %three_i32: i32 = 3;
  let %four_i32: i32 = 4;
  let %zero_i32: i32 = 0;
  let %one_f32: f32 = 1.0;
  let %two_f32: f32 = 2.0;
  let %three_f32: f32 = 3.0;
  let %four_f32: f32 = 4.0;
  let %zero_f32: f32 = 0.0;
  let mut %x: <4> i32 = 0;
  let mut %x: <4> i32 = 0;
  // Semcheck error: duplicate decl;

^entry:
  %pre_cond = cmp < %one_i32, %two_i32;
  %post_cond = cmp < %two_i32, %one_i32;
  %v_val[0] = 1;
  br %pre_cond != 0, ^pre_left, ^pre_right;

^pre_left:
  %x[0] = 1;
  %v_val[1] = 2;
  %v_val[2] = 3;
  br ^pre_merge;

^pre_right:
  %x[1] = 2;
  %v_val[3] = 4;
  %v_val[0] = 5;
  br ^pre_merge;

^pre_merge:
  %v_val[1] = 6;
  %v_val[2] = 7;
  %v_val[3] = 8;
  br ^loop_cond;

^loop_cond:
  %cond = cmp < %loop_idx, %two;
  %v_val[0] = 9;
  %v_val[1] = 10;
  br %cond != 0, ^body1, ^post_split;

^body1:
  %x[2] = 3;
  %v_val[2] = 11;
  %v_val[3] = 12;
  br ^body2;

^body2:
  %v_val[0] = 13;
  %v_val[1] = 14;
  %v_val[2] = 15;
  br ^latch;

^latch:
  %loop_idx = %loop_idx + 1;
  %v_val[3] = 16;
  %v_val[0] = 17;
  br ^loop_cond;

^post_split:
  %v_val[1] = 18;
  %v_val[2] = 19;
  %v_val[3] = 20;
  br %post_cond != 0, ^post_left, ^post_right;

^post_left:
  %v_val[0] = 21;
  %v_val[1] = 22;
  %v_val[2] = 23;
  br ^exit;

^post_right:
  %v_val[3] = 24;
  %v_val[0] = 25;
  %v_val[1] = 26;
  br ^exit;

^exit:
  %v_val[2] = 27;
  %v_val[3] = 28;
  %v_val[0] = 29;
  ret 0;
}

// EXPECT: PASS
// SPEC v0.2.2 §3.3 §9.6 §12
// INTERP_ARGS: -I test/lib/std/scalar
// Intention: vector + stdlib + intrinsic mix, ptr param to inner fun.
intrinsic @abs(%x: i32) : i32;
intrinsic @clz(%x: i32) : i32;
decl @gcd(%a: i32, %b: i32) : i32;

fun @bump(%p: ptr i32) : i32 {
  let mut %v: i32 = 0;
^entry:
  %v = load %p;
  store %p, %v + 1;
  ret %v;
}

fun @main() : i32 {
  let mut %v: <4> i32 = {2, 4, 6, 8};
  let mut %acc: i32 = 0;
  let mut %lane: i32 = 0;
  let mut %g: i32 = 0;
  let mut %ab: i32 = 0;
  let mut %cz: i32 = 0;
  let mut %bumped: i32 = 0;
  let mut %x: i32 = 16;
  let mut %final: i32 = 0;
^entry:
  %lane = %v[0];
  %acc = %v[0] + %v[1];
  %acc = %acc + %v[2];
  %acc = %acc + %v[3];
  br %acc > 0, ^b1, ^b2;
^b1:
  %bumped = call @bump(addr %x);
  %g = call @gcd(%acc, %x);
  %ab = call @abs(%lane);
  %cz = call @clz(%x);
  br %g >= 1, ^b3, ^b4;
^b2:
  %g = 0;
  br %g == 0, ^b3, ^b4;
^b3:
  %final = %g + %ab + %cz;
  ret %final;
^b4:
  %final = 0;
  ret %final;
}

// EXPECT: PASS

// Two vector arguments plus a trailing scalar: each argument must land
// in its own slot and the scalar must not be disturbed by the vector
// spills that precede it.

fun @dot(%a: <4> i32, %b: <4> i32, %c: i32) : i32 {
  let mut %s: i32 = 0;
  let mut %t: i32 = 0;
^entry:
  %t = %a[0];
  %t = %t * %b[0];
  %s = %s + %t;
  %t = %a[1];
  %t = %t * %b[1];
  %s = %s + %t;
  %t = %a[2];
  %t = %t * %b[2];
  %s = %s + %t;
  %t = %a[3];
  %t = %t * %b[3];
  %s = %s + %t;
  %s = %s + %c;
  ret %s;
}

fun @main() : i32 {
  let mut %a: <4> i32 = { 1, 2, 3, 4 };
  let mut %b: <4> i32 = { 10, 20, 30, 40 };
  let mut %r: i32 = 0;
^entry:
  %r = call @dot(%a, %b, 1000);
  require %r == 1300, "dot(a, b) + c must be 300 + 1000";
  ret %r;
}

// EXPECT: PASS


// Lane-wise vector arithmetic, lane read/write, whole-vector copy.
fun @main(): i32 {
    let mut %a: <4> i32 = {1, 2, 3, 4};
    let mut %b: <4> i32 = {10, 20, 30, 40};
    let mut %r: <4> i32 = 0;
    let mut %c: <4> i32 = 0;
    let mut %v: i32 = 0;
^entry:
    %r = %a + %b;
    require %r[0] == 11, "lane add 0";
    require %r[3] == 44, "lane add 3";
    %r = 2 * %b;
    require %r[2] == 60, "scalar broadcast multiply";
    %r = %b / %a;
    require %r[1] == 10, "lane divide";
    %c = %r;
    %c[0] = 99;
    require %r[0] == 10, "whole-vector copy does not alias";
    require %c[0] == 99, "copy is writable";
    %v = %a[3];
    require %v == 4, "lane read";
    ret %v;
}

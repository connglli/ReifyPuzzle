// EXPECT: PASS

// Vector local initialization forms under every vec-lowering strategy:
// aggregate init, scalar broadcast, undef + lane writes, literal lane
// reads. No dynamic lane indices, so all strategies (including
// 'scalars') accept this program.

fun @main() : i32 {
  let mut %a: <4> i32 = { 10, -20, 30, -40 };
  let mut %b: <4> i32 = 7;
  let mut %c: <4> i32 = undef;
  let mut %r: i32 = 0;
^entry:
  %c[0] = 1;
  %c[1] = %a[1];
  %c[2] = %b[2];
  %c[3] = 100;
  %r = %c[0] + %c[1];
  require %r == -19, "1 + -20";
  %r = %c[2] + %c[3];
  require %r == 107, "7 + 100";
  %r = %a[0] + %a[3];
  require %r == -30, "10 + -40";
  ret %r;
}

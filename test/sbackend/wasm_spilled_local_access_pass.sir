// EXPECT: PASS

// Checks that scalar variables whose address is taken (forced to live on the shadow stack)
// are correctly loaded when referenced as coefficients in expressions or as index offsets.
fun @main(): i32 {
    let mut %v1: i32 = 2;
    let mut %p1: ptr i32 = undef;
    let mut %arr: [4] i32 = {10, 20, 30, 40};
    let mut %one: i32 = 1;
    let mut %r: i32 = 0;
^entry:
    %p1 = addr %v1;           // Force %v1 onto the shadow stack

    // 1. Use %v1 as a coefficient in an OpAtom (%v1 >> %one)
    %r = %v1 >> %one;
    require %r == 1, "v1 >> one == 1";

    // 2. Use %v1 as an Index in ptrindex/subscript
    %r = %arr[%v1];
    require %r == 30, "arr[2] == 30";

    ret 0;
}

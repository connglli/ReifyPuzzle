// EXPECT: PASS

// @check_chksum on equal operands returns the actual value verbatim.

intrinsic @check_chksum(%expected: i32, %actual: i32) : i32;

fun @main(): i32 {
    let mut %r: i32 = 0;
^entry:
    %r = call @check_chksum(42, 42);
    require %r == 42, "check_chksum returns actual on match";
    ret %r;
}

// EXPECT: PASS

// Lane-wise compute under every vec-lowering strategy: i16 arithmetic
// (sub-word sign behavior), vector cmp producing an <N> i1 mask, and a
// mask-based select blend.

fun @main() : i32 {
  let mut %a: <4> i16 = { 100, -200, 300, -400 };
  let mut %b: <4> i16 = { 1, 2, 3, 4 };
  let mut %s: <4> i16 = undef;
  let mut %m: <4> i1 = undef;
  let mut %bl: <4> i16 = undef;
  let mut %r: i32 = 0;
  let mut %t: i32 = 0;
^entry:
  %s = %a + %b - %b;
  %m = cmp > %a, %b;
  %bl = select %m, %a, %b;
  %t = %s[1] as i32;
  %r = %t;
  require %r == -200, "a + b - b keeps lanes";
  %t = %bl[0] as i32;
  %r = %t;
  require %r == 100, "lane 0: 100 > 1 picks a";
  %t = %bl[1] as i32;
  %r = %t;
  require %r == 2, "lane 1: -200 <= 2 picks b";
  ret %r;
}

// EXPECT: PASS
// SKIP: C, WASM — structured-backend suite (goto-based c/wasm sweeps skip)

// Direct array element access with static and dynamic indices, plus a
// nested 2D array with broadcast init.
fun @main(): i32 {
    let mut %a: [4] i32 = {10, 20, 30, 40};
    let mut %m: [2] [3] i32 = 0;
    let mut %i: i32 = 0;
    let mut %acc: i32 = 0;
^entry:
    br ^head;

^head:
    br %i < 4, ^body, ^next;

^body:
    %acc = %acc + %a[%i];
    %i = %i + 1;
    br ^head;

^next:
    require %acc == 100, "sum of brace-initialized elements";
    %a[0] = 11;
    require %a[0] == 11, "element write";
    %m[1][2] = 7;
    require %m[1][2] == 7, "nested array element";
    require %m[0][2] == 0, "broadcast zero init";
    ret %acc;
}

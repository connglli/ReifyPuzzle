// EXPECT: FAIL:StaticError
// SKIP: C, WASM — structured-backend suite; plain c/wasm accept irreducible CFGs

// The python target only accepts reducible control flow.
fun @main(): i32 {
    let mut %x: i32 = 0;
^entry:
    br %x < 5, ^a, ^b;

^a:
    %x = %x + 1;
    br ^b;

^b:
    %x = %x + 2;
    br %x < 100, ^a, ^exit;

^exit:
    ret %x;
}

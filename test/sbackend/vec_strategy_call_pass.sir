// EXPECT: PASS

// Function boundary under every vec-lowering strategy: the memory ABI
// (spilled args + sret) must round-trip lanes regardless of how each
// side stores its vector locals, including a nested vector-returning
// call inside a vector expression.

fun @mk() : <4> i32 {
  let mut %v: <4> i32 = { 5, 6, 7, 8 };
^entry:
  ret %v;
}

fun @sum(%v: <4> i32) : i32 {
  let mut %s: i32 = 0;
^entry:
  %s = %v[0] + %v[1] + %v[2] + %v[3];
  ret %s;
}

fun @main() : i32 {
  let mut %w: <4> i32 = { 1, 1, 1, 1 };
  let mut %v: <4> i32 = undef;
  let mut %r: i32 = 0;
^entry:
  %v = call @mk();
  %r = call @sum(%v);
  require %r == 26, "5+6+7+8";
  %v = call @mk() + %w;
  %r = call @sum(%v);
  require %r == 30, "26 + 4";
  ret %r;
}

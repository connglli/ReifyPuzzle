// EXPECT: PASS
// SKIP: C, WASM — structured-backend suite (goto-based c/wasm sweeps skip)

// Reified vector comparison masks ({0,-1} lanes) and mask-form select.
fun @main(): i32 {
    let mut %a: <4> i32 = {1, 5, 3, 7};
    let mut %b: <4> i32 = {4, 4, 4, 4};
    let mut %m: <4> i1 = 0;
    let mut %r: <4> i32 = 0;
    let mut %t: i32 = 0;
^entry:
    %m = cmp < %a, %b;
    %t = %m[0] as i32;
    require %t == 0 - 1, "mask lane true is -1";
    %t = %m[1] as i32;
    require %t == 0, "mask lane false is 0";
    %r = select %m, %a, %b;
    require %r[0] == 1, "blend picks a where mask true";
    require %r[1] == 4, "blend picks b where mask false";
    require %r[3] == 4, "blend last lane";
    ret %r[2];
}

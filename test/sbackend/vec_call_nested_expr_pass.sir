// EXPECT: PASS

// A vector-returning call nested inside a vector expression must be
// evaluated exactly once and its lanes then combined like any other
// vector operand.

fun @mk() : <4> i32 {
  let mut %v: <4> i32 = { 5, 6, 7, 8 };
^entry:
  ret %v;
}

fun @main() : i32 {
  let mut %w: <4> i32 = { 1, 1, 1, 1 };
  let mut %v: <4> i32 = undef;
  let mut %r: i32 = 0;
^entry:
  %v = call @mk() + %w;
  %r = %v[0] + %v[3];
  require %r == 15, "6 + 9 from (mk() + w) lanes";
  ret %r;
}

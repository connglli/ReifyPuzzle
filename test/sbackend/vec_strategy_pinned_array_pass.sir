// EXPECT: PASS
// COMPILER_ARGS: --vec-lowering array

// Pinned 'array' strategy (supported by C, WASM, and python): keeps
// the frame-memory / lane-list storage exercised in CI now that the
// defaults are vecext (C, WASM) and array only for python — including
// the dynamic lane indices the register strategies handle differently.

fun @main() : i32 {
  let mut %v: <4> i32 = { 10, 20, 30, 40 };
  let mut %i: i32 = 1;
  let mut %r: i32 = 0;
^entry:
  %v[%i] = 200;
  %i = %i + 2;
  %r = %v[%i];
  require %r == 40, "dynamic read of lane 3";
  %r = %v[1];
  require %r == 200, "dynamic write of lane 1";
  ret %r;
}

// EXPECT: PASS

// Whole-vector copies under every vec-lowering strategy: init-from-local
// and block-body `%v = %w;` copy, with a write-after-copy proving the
// copy is by value (no aliasing between the two locals' storage).

fun @main() : i32 {
  let mut %v: <4> i32 = { 1, 2, 3, 4 };
  let mut %w: <4> i32 = %v;
  let mut %u: <4> i32 = undef;
  let mut %r: i32 = 0;
^entry:
  %u = %w;
  %w[0] = 100;
  %r = %u[0] + %w[0];
  require %r == 101, "copy is by value: u[0] stays 1";
  %r = %v[3] + %u[3];
  require %r == 8, "both copies carry lane 3";
  ret %r;
}

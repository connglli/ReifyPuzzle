// EXPECT: PASS

// f64 lanes (<4> f64 = two f64x2 registers under 'vecext'): float
// lanes across the register boundary and through the call boundary.

fun @twice(%v: <4> f64) : <4> f64 {
  let mut %w: <4> f64 = undef;
^entry:
  %w = %v + %v;
  ret %w;
}

fun @main() : i32 {
  let mut %v: <4> f64 = { 1.5, -2.25, 1000.125, 0.5 };
  let mut %w: <4> f64 = undef;
  let mut %r: f64 = 0.0;
^entry:
  %w = call @twice(%v);
  %r = %w[0] + %w[1];
  require %r == -1.5, "3.0 + -4.5";
  %r = %w[2] + %w[3];
  require %r == 2001.25, "2000.25 + 1.0";
  ret 0;
}

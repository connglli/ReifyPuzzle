// EXPECT: PASS

// f32 lanes across the call boundary: 4-byte float lane loads/stores
// on both the spilled-argument and the sret side.

fun @twice(%v: <4> f32) : <4> f32 {
  let mut %w: <4> f32 = undef;
^entry:
  %w = %v + %v;
  ret %w;
}

fun @main() : i32 {
  let mut %v: <4> f32 = { 1.5, -3.0, 8.0, 0.25 };
  let mut %w: <4> f32 = undef;
  let mut %r: f32 = 0.0;
^entry:
  %w = call @twice(%v);
  %r = %w[0] + %w[1];
  require %r == -3.0, "3.0 + -6.0";
  %r = %w[2] + %w[3];
  require %r == 16.5, "16.0 + 0.5";
  ret 0;
}

// SKIP: ALL — library / fixture file; not a standalone test
// stdlib/scalar/fabs_f32 -- absolute value of a finite f32.
//
// Consumers add `decl @fabs_f32(%x: f32) : f32;` and pass
//   `-I test/lib/std/scalar`
// to the tools.

// fabs_f32(x) -- |x| for any finite f32 x.
//
// Semantics:
//   `select x < 0, -x, x`. RefractIR rejects ±∞ / NaN as input domain so
//   negation cannot overflow (finite-only model, §2.9).
fun @fabs_f32(%x: f32) : f32 {
  let %zero: f32 = 0.0;
  let %neg_one: f32 = -1.0;
  let mut %negx: f32 = 0.0;
^entry:
  %negx = %neg_one * %x;
  ret select %x < %zero, %negx, %x;
}

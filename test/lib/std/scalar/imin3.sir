// stdlib/scalar/imin3 -- minimum of three i32 values.
//
// Consumers add `decl @imin3(%a: i32, %b: i32, %c: i32) : i32;` and
// pass `-I test/lib/std/scalar` to the tools.

intrinsic @min(%a: i32, %b: i32) : i32;

// imin3(a, b, c) -- minimum of three signed i32 values via two @min calls.
fun @imin3(%a: i32, %b: i32, %c: i32) : i32 {
  let mut %t: i32 = 0;
^entry:
  %t = call @min(%a, %b);
  ret call @min(%t, %c);
}

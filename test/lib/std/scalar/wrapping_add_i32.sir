// SKIP: ALL — library / fixture file; not a standalone test
// stdlib/scalar/wrapping_add_i32 -- 2's-complement wrapping addition.
//
// Consumers add `decl @wrapping_add_i32(%a: i32, %b: i32) : i32;`
// and pass `-I test/lib/std/scalar` to the tools.

// wrapping_add_i32(a, b) -- a + b reduced mod 2^32 in two's complement.
//
// Semantics:
//   RefractIR i32 `+` is UB on signed overflow, so we cannot just write
//   `a + b` and "let it wrap". Widening both operands to i64 (which
//   never overflows for two 32-bit summands) and truncating back via
//   `as i32` yields the standard 2's-complement wrap.
fun @wrapping_add_i32(%a: i32, %b: i32) : i32 {
  let mut %a64: i64 = 0;
  let mut %b64: i64 = 0;
  let mut %sum: i64 = 0;
  let mut %res: i32 = 0;
^entry:
  %a64 = %a as i64;
  %b64 = %b as i64;
  %sum = %a64 + %b64;
  %res = %sum as i32;
  ret %res;
}

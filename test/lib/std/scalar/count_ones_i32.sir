// stdlib/scalar/count_ones_i32 -- population count of an i32.
//
// Consumers add `decl @count_ones_i32(%x: i32) : i32;` and pass
//   `-I test/lib/std/scalar`
// to the tools.

intrinsic @popcount(%x: i32) : i32;

// count_ones_i32(x) -- returns the number of 1 bits in x.
//
// Inputs:
//   %x : i32  -- any value (including negative — bits are interpreted
//                as the two's-complement encoding).
//
// Output:
//   i32 in [0, 32].
//
// Semantics:
//   Thin wrapper over the @popcount intrinsic.
fun @count_ones_i32(%x: i32) : i32 {
^entry:
  ret call @popcount(%x);
}

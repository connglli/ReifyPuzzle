// SKIP: ALL — library / fixture file; not a standalone test
// stdlib/simd/vec_clamp_4_i32 -- lane-wise clamp into [lo, hi].
//
// Consumers add
//   `decl @vec_clamp_4_i32(%v: <4> i32, %lo: i32, %hi: i32) : <4> i32;`
// and pass `-I test/lib/std/simd` to the tools.

intrinsic @min(%a: i32, %b: i32) : i32;
intrinsic @max(%a: i32, %b: i32) : i32;

// vec_clamp_4_i32(v, lo, hi) -- each lane independently clamped to
// [lo, hi]. The bounds are scalar i32 values applied uniformly.
fun @vec_clamp_4_i32(%v: <4> i32, %lo: i32, %hi: i32) : <4> i32 {
  let %i0: i32 = 0;
  let %i1: i32 = 1;
  let %i2: i32 = 2;
  let %i3: i32 = 3;
  let mut %r: <4> i32 = { 0, 0, 0, 0 };
  let mut %t: i32 = 0;
  let mut %tmp: i32 = 0;
^entry:
  %t = %v[%i0]; %tmp = call @max(%t, %lo); %r[%i0] = call @min(%tmp, %hi);
  %t = %v[%i1]; %tmp = call @max(%t, %lo); %r[%i1] = call @min(%tmp, %hi);
  %t = %v[%i2]; %tmp = call @max(%t, %lo); %r[%i2] = call @min(%tmp, %hi);
  %t = %v[%i3]; %tmp = call @max(%t, %lo); %r[%i3] = call @min(%tmp, %hi);
  ret %r;
}

// stdlib/simd/dot_4_i32 -- dot product of two 4-lane i32 vectors.
//
// Consumers add `decl @dot_4_i32(%a: <4> i32, %b: <4> i32) : i32;` and
// pass `-I test/lib/std/simd` to the tools.

// dot_4_i32(a, b) -- sum_{i in [0,4)} a[i] * b[i].
//
// Semantics:
//   Lane-wise multiply produces a <4> i32 product vector; we then read
//   each lane individually and sum into an i32 accumulator (no
//   horizontal-reduce intrinsic in v0.2.2).
//
// UB:
//   Per-lane signed-overflow rules apply to the lane-wise multiply
//   (any lane overflow makes the path infeasible), plus standard
//   scalar overflow on the running sum.
fun @dot_4_i32(%a: <4> i32, %b: <4> i32) : i32 {
  let %i0: i32 = 0;
  let %i1: i32 = 1;
  let %i2: i32 = 2;
  let %i3: i32 = 3;
  let mut %prod: <4> i32 = { 0, 0, 0, 0 };
  let mut %t: i32 = 0;
  let mut %acc: i32 = 0;
^entry:
  %prod = %a * %b;
  %t = %prod[%i0]; %acc = %acc + %t;
  %t = %prod[%i1]; %acc = %acc + %t;
  %t = %prod[%i2]; %acc = %acc + %t;
  %t = %prod[%i3]; %acc = %acc + %t;
  ret %acc;
}

// stdlib/simd/broadcast_4_i32 -- splat an i32 across 4 lanes.
//
// Consumers add `decl @broadcast_4_i32(%x: i32) : <4> i32;` and pass
//   `-I test/lib/std/simd`
// to the tools.

// broadcast_4_i32(x) -- the vector { x, x, x, x }.
//
// Semantics:
//   Scalar-to-vector broadcast from a non-literal source is done
//   lane-by-lane. (Initializing a `<N> T` local from a scalar literal
//   would broadcast at declaration time, but we want a runtime value.)
fun @broadcast_4_i32(%x: i32) : <4> i32 {
  let %i0: i32 = 0;
  let %i1: i32 = 1;
  let %i2: i32 = 2;
  let %i3: i32 = 3;
  let mut %v: <4> i32 = { 0, 0, 0, 0 };
^entry:
  %v[%i0] = %x;
  %v[%i1] = %x;
  %v[%i2] = %x;
  %v[%i3] = %x;
  ret %v;
}

// SKIP: ALL — library / fixture file; not a standalone test
// stdlib/collections/array_count_eq_i32 -- count matching elements.
//
// Consumers add
//   `decl @array_count_eq_i32(%p: ptr i32, %n: i32, %needle: i32) : i32;`
// and pass `-I test/lib/std/collections` to the tools.

// array_count_eq_i32(p, n, needle) -- number of i in [0, n) with
// p[i] == needle.
fun @array_count_eq_i32(%p: ptr i32, %n: i32, %needle: i32) : i32 {
  let %zero: i32 = 0;
  let %one: i32 = 1;
  let mut %i: i32 = 0;
  let mut %count: i32 = 0;
  let mut %cur: ptr i32 = null;
  let mut %val: i32 = 0;
^entry:
  %i = %zero;
  %count = %zero;
  br %zero == %zero, ^loop_cond, ^exit;

^loop_cond:
  br %i < %n, ^loop_body, ^exit;

^loop_body:
  %cur = %p + %i;
  %val = load %cur;
  br %val == %needle, ^bump, ^step;

^bump:
  %count = %count + %one;
  br %zero == %zero, ^step, ^exit;

^step:
  %i = %i + %one;
  br %zero == %zero, ^loop_cond, ^exit;

^exit:
  ret %count;
}

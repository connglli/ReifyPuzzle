// SKIP: ALL — library / fixture file; not a standalone test
// stdlib/collections/array_lower_bound_i32 -- binary search lower_bound.
//
// Consumers add
//   `decl @array_lower_bound_i32(%p: ptr i32, %n: i32, %key: i32) : i32;`
// and pass `-I test/lib/std/collections` to the tools.

// array_lower_bound_i32(p, n, key) -- first index i in [0, n] such
// that p[i] >= key (or n if all elements are < key).
//
// Inputs:
//   %p  : ptr i32 -- non-null pointer to an initialized buffer sorted
//                    non-decreasing (caller obligation).
//   %n  : i32     -- element count (n >= 0).
//   %key: i32     -- search key.
//
// Output:
//   i32 in [0, n].
//
// Semantics:
//   Standard half-open binary search. We avoid the (lo + hi)
//   overflow pitfall by computing the midpoint as lo + (hi - lo) / 2.
fun @array_lower_bound_i32(%p: ptr i32, %n: i32, %key: i32) : i32 {
  let %zero: i32 = 0;
  let %two: i32 = 2;
  let %one: i32 = 1;
  let mut %lo: i32 = 0;
  let mut %hi: i32 = 0;
  let mut %mid: i32 = 0;
  let mut %half: i32 = 0;
  let mut %cur: ptr i32 = null;
  let mut %val: i32 = 0;
^entry:
  %lo = %zero;
  %hi = %n;
  br %zero == %zero, ^loop_cond, ^exit;

^loop_cond:
  br %lo < %hi, ^loop_body, ^exit;

^loop_body:
  %half = %hi - %lo;
  %half = %half / %two;
  %mid = %lo + %half;
  %cur = %p + %mid;
  %val = load %cur;
  br %val < %key, ^go_right, ^go_left;

^go_right:
  %lo = %mid + %one;
  br %zero == %zero, ^loop_cond, ^exit;

^go_left:
  %hi = %mid;
  br %zero == %zero, ^loop_cond, ^exit;

^exit:
  ret %lo;
}

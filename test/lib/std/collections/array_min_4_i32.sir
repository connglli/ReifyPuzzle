// stdlib/collections/array_min_4_i32 -- min of a length-4 i32 array.
//
// Consumers add `decl @array_min_4_i32(%p: ptr [4] i32) : i32;` and
// pass `-I test/lib/std/collections` to the tools.

intrinsic @min(%a: i32, %b: i32) : i32;

// array_min_4_i32(p) -- minimum element of a 4-element array.
fun @array_min_4_i32(%p: ptr [4] i32) : i32 {
  let %i0: i32 = 0;
  let %i1: i32 = 1;
  let %i2: i32 = 2;
  let %i3: i32 = 3;
  let mut %elt: ptr i32 = null;
  let mut %v0: i32 = 0;
  let mut %v1: i32 = 0;
  let mut %v2: i32 = 0;
  let mut %v3: i32 = 0;
  let mut %m: i32 = 0;
^entry:
  %elt = ptrindex %p, %i0; %v0 = load %elt;
  %elt = ptrindex %p, %i1; %v1 = load %elt;
  %elt = ptrindex %p, %i2; %v2 = load %elt;
  %elt = ptrindex %p, %i3; %v3 = load %elt;
  %m = call @min(%v0, %v1);
  %m = call @min(%m, %v2);
  %m = call @min(%m, %v3);
  ret %m;
}

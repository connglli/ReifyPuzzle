// stdlib/collections/array_find_i32 -- linear search.
//
// Consumers add
//   `decl @array_find_i32(%p: ptr i32, %n: i32, %needle: i32) : i32;`
// and pass `-I test/lib/std/collections` to the tools.

// array_find_i32(p, n, needle) -- index of the first occurrence, or n.
//
// Inputs:
//   %p      : ptr i32 -- base pointer (allowed to alias one-past-end
//                        only if %n == 0).
//   %n      : i32     -- element count.
//   %needle : i32     -- value to look for.
//
// Output:
//   i32 -- the smallest i in [0, n) with p[i] == needle, or n if absent.
//
// Semantics:
//   Iterates an index `i` from 0 to n - 1, loading p + i and comparing
//   against the needle. Returns immediately on first match.
fun @array_find_i32(%p: ptr i32, %n: i32, %needle: i32) : i32 {
  let %zero: i32 = 0;
  let %one: i32 = 1;
  let mut %i: i32 = 0;
  let mut %cur: ptr i32 = null;
  let mut %val: i32 = 0;
^entry:
  %i = %zero;
  br %zero == %zero, ^loop_cond, ^exit;

^loop_cond:
  br %i < %n, ^loop_body, ^not_found;

^loop_body:
  %cur = %p + %i;
  %val = load %cur;
  br %val == %needle, ^found, ^step;

^step:
  %i = %i + %one;
  br %zero == %zero, ^loop_cond, ^exit;

^found:
  ret %i;

^not_found:
  ret %n;

^exit:
  ret %n;
}

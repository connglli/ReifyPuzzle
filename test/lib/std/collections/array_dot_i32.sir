// SKIP: ALL — library / fixture file; not a standalone test
// stdlib/collections/array_dot_i32 -- dot product of two i32 arrays.
//
// Consumers add
//   `decl @array_dot_i32(%a: ptr [4] i32, %b: ptr [4] i32) : i32;`
// and pass `-I test/lib/std/collections` to the tools.

// array_dot_i32(a, b) -- sum_{i in [0,4)} a[i] * b[i].
//
// Inputs:
//   %a, %b : ptr [4] i32 -- non-null pointers to initialized arrays.
//
// Output:
//   i32 -- the inner product, summed left-to-right at i32 width.
//
// UB:
//   Signed overflow in any intermediate multiplication or sum (rule 4).
fun @array_dot_i32(%a: ptr [4] i32, %b: ptr [4] i32) : i32 {
  let %i0: i32 = 0;
  let %i1: i32 = 1;
  let %i2: i32 = 2;
  let %i3: i32 = 3;
  let mut %ap: ptr i32 = null;
  let mut %bp: ptr i32 = null;
  let mut %av: i32 = 0;
  let mut %bv: i32 = 0;
  let mut %prod: i32 = 0;
  let mut %acc: i32 = 0;
^entry:
  %ap = ptrindex %a, %i0; %av = load %ap;
  %bp = ptrindex %b, %i0; %bv = load %bp;
  %prod = %av * %bv;
  %acc = %acc + %prod;
  %ap = ptrindex %a, %i1; %av = load %ap;
  %bp = ptrindex %b, %i1; %bv = load %bp;
  %prod = %av * %bv;
  %acc = %acc + %prod;
  %ap = ptrindex %a, %i2; %av = load %ap;
  %bp = ptrindex %b, %i2; %bv = load %bp;
  %prod = %av * %bv;
  %acc = %acc + %prod;
  %ap = ptrindex %a, %i3; %av = load %ap;
  %bp = ptrindex %b, %i3; %bv = load %bp;
  %prod = %av * %bv;
  %acc = %acc + %prod;
  ret %acc;
}

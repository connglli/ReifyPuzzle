// stdlib/collections/array_contains_i32 -- membership test.
//
// Consumers add
//   `decl @array_contains_i32(%p: ptr i32, %n: i32, %needle: i32) : i32;`
// and pass `-I test/lib/std/collections` to the tools.

// array_contains_i32(p, n, needle) -- 1 if needle appears in p[0..n),
// else 0.
fun @array_contains_i32(%p: ptr i32, %n: i32, %needle: i32) : i32 {
  let %zero: i32 = 0;
  let %one: i32 = 1;
  let mut %i: i32 = 0;
  let mut %cur: ptr i32 = null;
  let mut %val: i32 = 0;
^entry:
  %i = %zero;
  br %zero == %zero, ^loop_cond, ^exit;

^loop_cond:
  br %i < %n, ^loop_body, ^miss;

^loop_body:
  %cur = %p + %i;
  %val = load %cur;
  br %val == %needle, ^hit, ^step;

^step:
  %i = %i + %one;
  br %zero == %zero, ^loop_cond, ^exit;

^hit:
  ret %one;

^miss:
  ret %zero;

^exit:
  ret %zero;
}

control-tree @main:
  block ^entry
  loop 0 header=^head
    block ^head
    if ^head
      then:
        block ^body
        if ^body
          then:
            block ^a
            fallthrough ^latch
          else:
            block ^b
            fallthrough ^latch
        block ^latch
        continue ^head levels=0
      else:
        break ^exit levels=1
  block ^exit
  return ^exit

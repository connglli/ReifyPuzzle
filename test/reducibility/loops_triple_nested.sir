// EXPECT: PASS
// COMPILER_ARGS: --dump-loops

// Three-deep nest: the innermost loop is contained in BOTH outer
// loops; its parent must be the containing loop with the deepest
// header (^mid_head), not the outermost.
fun @main(): i32 {
    let mut %i: i32 = 0;
    let mut %j: i32 = 0;
    let mut %k: i32 = 0;
    let mut %acc: i32 = 0;
^entry:
    br ^out_head;

^out_head:
    br %i < 4, ^mid_init, ^done;

^mid_init:
    %j = 0;
    br ^mid_head;

^mid_head:
    br %j < 4, ^in_init, ^out_latch;

^in_init:
    %k = 0;
    br ^in_head;

^in_head:
    br %k < 4, ^in_body, ^mid_latch;

^in_body:
    %acc = %acc + 1;
    %k = %k + 1;
    br ^in_head;

^mid_latch:
    %j = %j + 1;
    br ^mid_head;

^out_latch:
    %i = %i + 1;
    br ^out_head;

^done:
    ret %acc;
}

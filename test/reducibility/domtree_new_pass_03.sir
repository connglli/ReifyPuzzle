// EXPECT: PASS
// COMPILER_ARGS: --dump-domtree

// Test 3: Nested diamond structures.
fun @main(): i32 {
    let mut %x: i32 = 0;
^entry:
    br %x < 5, ^left, ^right;
^left:
    br %x < 2, ^left_left, ^left_right;
^left_left:
    br ^left_merge;
^left_right:
    br ^left_merge;
^left_merge:
    br ^merge;
^right:
    br ^merge;
^merge:
    ret %x;
}

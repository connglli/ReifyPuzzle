// EXPECT: FAIL:StaticError
// COMPILER_ARGS: --require-reducible

// A nested loop where:
// 1. ^inner_init can branch to ^dest or ^inner_head.
// 2. ^inner_body can branch to ^dest or ^inner_head (back-edge).
// 3. ^dest branches unconditionally back to ^inner_body.
// Since ^dest can be reached both from ^inner_init (bypassing ^inner_body)
// and from ^inner_body, neither ^inner_body nor ^dest dominates the other,
// yet they form a cycle. This is irreducible.
fun @main(): i32 {
    let mut %i: i32 = 0;
    let mut %j: i32 = 0;
    let mut %acc: i32 = 0;
^entry:
    br ^outer_head;

^outer_head:
    br %i < 10, ^inner_init, ^done;

^inner_init:
    %j = 0;
    br %acc < 0, ^dest, ^inner_head;

^inner_head:
    br %j < 10, ^inner_body, ^outer_latch;

^inner_body:
    %acc = %acc + %j;
    %j = %j + 1;
    br %acc > 5, ^dest, ^inner_head;

^dest:
    br ^inner_body;

^outer_latch:
    %i = %i + 1;
    br ^outer_head;

^done:
    ret %acc;
}

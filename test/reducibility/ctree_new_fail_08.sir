// EXPECT: FAIL:StaticError
// COMPILER_ARGS: --dump-control-tree

// Fail 8: Nested loop with irreducible cross jump.
fun @main(): i32 {
    let mut %i: i32 = 0;
    let mut %j: i32 = 0;
    let mut %acc: i32 = 0;
^entry:
    br ^outer_head;
^outer_head:
    br %i < 10, ^inner_init, ^done;
^inner_init:
    %j = 0;
    br %acc < 0, ^dest, ^inner_head;
^inner_head:
    br %j < 10, ^inner_body, ^outer_latch;
^inner_body:
    %acc = %acc + %j;
    %j = %j + 1;
    br %acc > 5, ^dest, ^inner_head;
^dest:
    br ^inner_body;
^outer_latch:
    %i = %i + 1;
    br ^outer_head;
^done:
    ret %acc;
}

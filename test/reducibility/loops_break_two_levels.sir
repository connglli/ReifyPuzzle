// EXPECT: PASS
// COMPILER_ARGS: --dump-loops

// ^ib exits BOTH loops at once (a two-level break): the edge
// ^ib->^done appears in the exit set of the inner AND the outer loop.
fun @main(): i32 {
    let mut %i: i32 = 0;
    let mut %j: i32 = 0;
    let mut %acc: i32 = 0;
^entry:
    br ^oh;

^oh:
    br %i < 10, ^ih, ^done;

^ih:
    br %j < 10, ^ib, ^ol;

^ib:
    %acc = %acc + %j;
    br %acc > 50, ^done, ^il;

^il:
    %j = %j + 1;
    br ^ih;

^ol:
    %i = %i + 1;
    br ^oh;

^done:
    ret %acc;
}

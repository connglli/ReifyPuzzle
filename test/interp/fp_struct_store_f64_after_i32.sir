// EXPECT: PASS
// Companion to fp_struct_store_f64_after_i16_array.sir.  Struct
// `{i32; f64}` has minFieldSize = 4 (sizeof(i32)).  The same buggy
// path narrowed the f64 store to f32, dropping precision.
intrinsic @to_bits(%x: f64) : i64;

struct @S { x: i32; f1: f64; }

fun @main() : i64 {
  let mut %t0: @S = {0, 1.0};
  let mut %ap0: ptr @S = undef;
  let mut %p1: ptr f64 = undef;
^entry:
  %ap0 = addr %t0;
  %p1 = ptrfield %ap0, f1;
  store %p1, -268435455.53125;
  require call @to_bits(%t0.f1) == -4490088828504113152, "i32+f64 struct: f64 stays exact";
  ret 0;
}

// EXPECT: PASS
// SPEC v0.2.2 §9.6.1 step 1 - 3 calls in single expression, mutate shared cell
fun @push(%p: ptr [4] i32, %v: i32) : i32 {
  let mut %ep: ptr i32 = null;
  let mut %idx: ptr i32 = null;
  let mut %i: i32 = 0;
^entry:
  %idx = ptrindex %p, 0; // use slot 0 as next-index counter
  %i = load %idx;
  %ep = ptrindex %p, %i + 1;
  store %ep, %v;
  %i = %i + 1;
  store %idx, %i;
  ret %v;
}
fun @main() : i32 {
  let mut %a: [4] i32 = { 0, 0, 0, 0 };
  let mut %pa: ptr [4] i32 = null;
  let mut %s: i32 = 0;
  let mut %got: i32 = 0;
  let mut %ep: ptr i32 = null;
^entry:
  %pa = addr %a;
  %s = call @push(%pa, 10) + call @push(%pa, 20) + call @push(%pa, 30); // 10+20+30=60
  br %s == 60, ^chk, ^bad;
^chk:
  %ep = ptrindex %pa, 3;
  %got = load %ep;
  br %got == 30, ^ok, ^bad;
^ok:
  ret 0;
^bad:
  ret 1;
}

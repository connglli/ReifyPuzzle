// EXPECT: PASS
// Pointers within the same originating object can be compared with `<`.
// addr arr[0] < addr arr[3] must hold.
fun @main() : i32 {
  let mut %arr: [4] i32 = {0, 0, 0, 0};
  let mut %p: ptr i32 = null;
  let mut %q: ptr i32 = null;
^entry:
  %p = addr %arr[0];
  %q = addr %arr[3];
  br %p < %q, ^ok, ^bad;
^ok:
  ret 0;
^bad:
  require 0 == 1, "p should be less than q";
  ret 1;
}

// EXPECT: FAIL
// SPEC v0.2.2 §12 chain triggers UB inside @abs
intrinsic @abs(%x: i32) : i32;
intrinsic @min(%a: i32, %b: i32) : i32;
fun @main() : i32 {
  let mut %r: i32 = 0;
  let %im: i32 = -2147483648;
^entry:
  %r = call @abs(call @min(%im, 0)); // min -> INT_MIN, abs(INT_MIN) UB
  ret %r;
}

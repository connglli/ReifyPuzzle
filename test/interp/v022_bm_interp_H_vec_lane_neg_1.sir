// EXPECT: FAIL
// SKIP: WASM — WASM runtime has no UBSan-equivalent for vector lane OOB;
// this only trapped by accident while vector args were passed as a
// garbage byte-load instead of an address (fixed in v0.2.3).
// SPEC v0.2.2 §7.6 rule 20 negative lane in callee
fun @neg_lane(%v: <4> i32) : i32 {
  let %i: i32 = -1;
^entry:
  ret %v[%i];
}
fun @main() : i32 {
  let mut %v: <4> i32 = { 1, 2, 3, 4 };
^entry:
  ret call @neg_lane(%v);
}

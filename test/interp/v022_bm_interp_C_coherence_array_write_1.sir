// EXPECT: PASS
// SPEC v0.2.2 §9.6.1 step 5 - array coherence via load
fun @write_idx(%p: ptr [4] i32, %i: i32, %v: i32) : i32 {
  let mut %ep: ptr i32 = null;
^entry:
  %ep = ptrindex %p, %i;
  store %ep, %v;
  ret 0;
}
fun @main() : i32 {
  let mut %a: [4] i32 = { 0, 0, 0, 0 };
  let mut %pa: ptr [4] i32 = null;
  let mut %ep: ptr i32 = null;
  let mut %r: i32 = 0;
  let mut %got: i32 = 0;
^entry:
  %pa = addr %a;
  %r = call @write_idx(%pa, 1, 33);
  %r = call @write_idx(%pa, 3, 77);
  %ep = ptrindex %pa, 1;
  %got = load %ep;
  br %got == 33, ^c2, ^bad;
^c2:
  %ep = ptrindex %pa, 3;
  %got = load %ep;
  br %got == 77, ^ok, ^bad;
^ok:
  ret 0;
^bad:
  ret 1;
}

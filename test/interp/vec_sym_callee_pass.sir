// EXPECT: PASS
// SKIP: COMPILER
// INTERP_ARGS: --sym %?w=1,2,3,4

// Vector sym declared in a *callee*: exercises the nested-call sym
// binding path (which historically only materialized scalars).
fun @leaf() : i32 {
  sym %?w : value <4> i32;
  let mut %v: <4> i32 = %?w;
^entry:
  ret %v[2];
}
fun @main() : i32 {
  let mut %r: i32 = 0;
^entry:
  %r = call @leaf();
  require %r == 3, "callee vector sym lane";
  ret %r;
}

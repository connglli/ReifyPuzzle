// EXPECT: PASS
// SPEC v0.2.2 §12.4 @is_pow2 at i32 (returns i1)
intrinsic @is_pow2(%x: i32) : i1;
fun @main() : i32 {
  let mut %a: i1 = 0;
  let mut %b: i1 = 0;
  let mut %c: i1 = 0;
^entry:
  %a = call @is_pow2(16);   // true
  %b = call @is_pow2(0);    // false (not positive)
  %c = call @is_pow2(6);    // false (popcount != 1)
  br %a == 1, ^a_ok, ^bad;
^a_ok:
  br %b == 0, ^b_ok, ^bad;
^b_ok:
  br %c == 0, ^c_ok, ^bad;
^c_ok:
  ret 0;
^bad:
  ret 1;
}

// EXPECT: PASS
// SPEC v0.2.2 §12.6 @fabs at f32 — subnormal values survive without flush.
intrinsic @fabs(%x: f32) : f32;
fun @main() : i32 {
  let %tiny: f32 = 1.4e-39;
  let %neg_tiny: f32 = -1.4e-39;
  let mut %r: f32 = 0.0;
^entry:
  %r = call @fabs(%neg_tiny);
  require %r == %tiny, "fabs preserves subnormal magnitude";
  ret 0;
}

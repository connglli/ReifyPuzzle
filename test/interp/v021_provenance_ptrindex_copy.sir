// EXPECT: PASS
// SOLVER_ARGS: --main @main --path '^entry'
// SKIP: COMPILER

// Provenance propagation: ptrindex → copy → arith → load.
// ptrindex %parr, 1 → %pe → %pe2. Provenance = the array.
// %pe2 + 1 lands on arr[2] → valid.
fun @main() : i32 {
  let mut %arr: [4] i32 = {10, 20, 30, 40};
  let mut %parr: ptr [4] i32 = null;
  let mut %pe: ptr i32 = null;
  let mut %pe2: ptr i32 = null;
  let mut %val: i32 = 0;
^entry:
  %parr = addr %arr;
  %pe = ptrindex %parr, 1;
  %pe2 = %pe;
  %pe2 = %pe2 + 1;
  %val = load %pe2;
  require %val == 30, "pe2 should read arr[2]";
  ret 0;
}

// EXPECT: FAIL
// SPEC v0.2.2 §7.5 rule 16
struct @ArrHold { arr: [4] i32; }

fun @read_arr(%p: ptr @ArrHold, %i: i32) : i32 {
  let mut %pa: ptr [4] i32 = null;
  let mut %ep: ptr i32 = null;
^entry:
  %pa = ptrfield %p, arr;
  %ep = ptrindex %pa, %i; // OOB if %i out of [0,4]
  ret load %ep;
}
fun @main() : i32 {
  let mut %h: @ArrHold = { { 10, 20, 30, 40 } };
^entry:
  ret call @read_arr(addr %h, 9);
}

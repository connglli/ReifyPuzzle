// EXPECT: PASS
// EXPECT_RC: 10
// SPEC v0.2.2 §11.1
// INTERP_ARGS: -I test/lib/std/collections
// COMPILER_ARGS: -I test/lib/std/collections
// Intention: Uses stdlib array_sum_4_i32 (ptr-to-array) + local helper.
decl @array_sum_4_i32(%p: ptr [4] i32) : i32;

fun @bm_local_double(%x: i32) : i32 {
  let mut %y: i32 = 0;
  let %two: i32 = 2;
^entry:
  %y = %x * %two;
  br %y > 0, ^pos, ^neg;
^pos:
  ret %y;
^neg:
  ret 0 - %y;
}

fun @main() : i32 {
  let mut %arr: [4] i32 = {1, 2, 3, 4};
  let mut %p: ptr [4] i32 = null;
  let mut %s: i32 = 0;
  let mut %d: i32 = 0;
  let %five: i32 = 5;
^entry:
  %p = addr %arr;
  %s = call @array_sum_4_i32(%p);
  %d = call @bm_local_double(%s);
  br %d > %five, ^big, ^small;
^big:
  ret %d - %s;
^small:
  ret %d + %s;
}

// EXPECT: FAIL:UndefinedBehavior
// SPEC v0.2.2 §12.6 @from_bits UB — bit pattern of +∞ (0x7F800000) is
// non-finite, violating the §2.9 finite-only domain.
intrinsic @from_bits(%x: i32) : f32;
fun @main() : i32 {
  let mut %r: f32 = 0.0;
^entry:
  %r = call @from_bits(2139095040);  // 0x7F800000
  ret 0;
}

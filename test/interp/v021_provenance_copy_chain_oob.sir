// EXPECT: FAIL:UndefinedBehavior
// SOLVER_ARGS: --main @main --path '^entry'
// SKIP: COMPILER

// Provenance propagation: OOB through a copy chain.
// addr %x → %p1 → %p2 → %p3. Provenance = single scalar %x (size 1).
// %p3 + 2 exceeds the one-past-end (which is base + 1) → UB (rule 10).
fun @main() : i32 {
  let mut %x: i32 = 42;
  let mut %p1: ptr i32 = null;
  let mut %p2: ptr i32 = null;
  let mut %p3: ptr i32 = null;
^entry:
  %p1 = addr %x;
  %p2 = %p1;
  %p3 = %p2;
  %p3 = %p3 + 2;   // UB: 2 > 1 (one-past-end of single element)
  ret 0;
}

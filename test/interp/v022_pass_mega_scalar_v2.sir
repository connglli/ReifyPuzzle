// EXPECT: PASS
// INTERP_ARGS: -I test/tmp/external_i32
// COMPILER_ARGS: -I test/tmp/external_i32
// Rationale: [v0.2.2] - Exhaustive intrinsics, call logic, and scalar types (i32, f32) across 5+ blocks.
intrinsic @abs(%x: i32) : i32;
intrinsic @min(%a: i32, %b: i32) : i32;
intrinsic @max(%a: i32, %b: i32) : i32;
intrinsic @clz(%x: i32) : i32;
intrinsic @ctz(%x: i32) : i32;
intrinsic @popcount(%x: i32) : i32;

decl @external_helper(%x: i32) : i32;

fun @internal_helper(%x: f32) : f32 {
  let %two: f32 = 2.0;
  let %one: f32 = 1.0;
  let mut %y: f32 = 0.0;
  let mut %z: f32 = 0.0;
  let mut %res: f32 = 0.0;
^entry:
  %y = %x * %two;
  %z = %y + %one;
  %res = select %z > %one, %z, %one;
  ret %res;
}

fun @main() : i32 {
  let mut %acc: i32 = 0;
  let %v1: i32 = -10;
  let %v2: i32 = 20;
  let %f1: f32 = 3.14;
  let %c1: i32 = 1;
  let mut %abs1: i32 = 0;
  let mut %min1: i32 = 0;
  let mut %max1: i32 = 0;
  let mut %clz1: i32 = 0;
  let mut %ctz1: i32 = 0;
  let mut %pop1: i32 = 0;
  let mut %fret: f32 = 0.0;
  let mut %intf: i32 = 0;
  let mut %ext: i32 = 0;
  let mut %tmp: i32 = 0;
  let mut %sub: i32 = 0;
  let mut %ext2: i32 = 0;
  let mut %final: i32 = 0;
^entry:
  %abs1 = call @abs(%v1);
  %min1 = call @min(%abs1, %v2);
  %max1 = call @max(%abs1, %v2);
  %acc = %min1 + %max1;
  br %acc > 0, ^b1, ^b2;

^b1:
  %clz1 = call @clz(%c1);
  %ctz1 = call @ctz(%c1);
  %pop1 = call @popcount(%c1);
  %acc = %clz1 + %ctz1;
  %acc = %acc + %pop1;
  br %acc == 32, ^b3, ^b4; // clz(1)=31, ctz(1)=0, pop(1)=1 -> 32

^b2:
  %fret = call @internal_helper(%f1);
  %intf = %fret as i32;
  %acc = %acc + %intf;
  br %acc == 0, ^b3, ^b4;

^b3:
  %ext = call @external_helper(%acc);
  %tmp = %acc + %ext;
  %acc = %tmp * %c1;
  br %acc > 0, ^exit, ^exit;

^b4:
  %sub = %acc - %c1;
  %ext2 = call @external_helper(%sub);
  %acc = %ext2;
  br %acc < 0, ^exit, ^exit;

^exit:
  %final = %acc;
  ret 0;
}

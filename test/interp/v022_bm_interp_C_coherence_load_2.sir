// Intention: callee writes to caller's array element; caller reads via load and observes.
fun @set_elt(%p: ptr [4] i32, %i: i32, %v: i32) : i32 {
  let mut %ep: ptr i32 = null;
^entry:
  %ep = ptrindex %p, %i;
  store %ep, %v;
  ret %v;
}
fun @main() : i32 {
  let mut %a: [4] i32 = { 0, 0, 0, 0 };
  let mut %r: i32 = 0;
  let mut %got: i32 = 0;
  let mut %ep: ptr i32 = null;
  let mut %pa: ptr [4] i32 = null;
^entry:
  %pa = addr %a;
  %r = call @set_elt(%pa, 2, 77);
  %ep = ptrindex %pa, 2;
  %got = load %ep;
  br %got == 77, ^ok, ^bad;
^ok:
  ret 0;
^bad:

// EXPECT: FAIL
// SPEC v0.2.2 §7.5 rule 16
// Intention: callee ptrindex out of bounds (index N+1).
fun @bad_idx(%p: ptr [4] i32) : i32 {
  let mut %ep: ptr i32 = null;
^entry:
  %ep = ptrindex %p, 10; // OOB
  store %ep, 1;
  ret 0;
}
fun @main() : i32 {
  let mut %a: [4] i32 = { 0, 0, 0, 0 };
^entry:
  ret call @bad_idx(addr %a);
}

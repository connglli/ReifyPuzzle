// EXPECT: PASS
// SPEC v0.2.2 §12.6 D.2 @is_subnormal at f64 — the smallest positive
// subnormal returns 1.
intrinsic @is_subnormal(%x: f64) : i1;
intrinsic @from_bits(%x: i64) : f64;
fun @main() : i32 {
  let mut %sub: f64 = 0.0;
  let mut %r: i1 = 0;
^entry:
  %sub = call @from_bits(1);         // smallest +subnormal f64
  %r = call @is_subnormal(%sub);
  require %r == -1, "is_subnormal(min subnormal) == 1";
  ret 0;
}

// EXPECT: PASS
// SPEC v0.2.2 §12.6 @signbit at f32 — subnormals report sign correctly.
intrinsic @signbit(%x: f32) : i1;
fun @main() : i32 {
  let %neg_tiny: f32 = -1.4e-39;
  let %pos_tiny: f32 = 1.4e-39;
  let mut %s_neg: i1 = 0;
  let mut %s_pos: i1 = 0;
^entry:
  %s_neg = call @signbit(%neg_tiny);
  %s_pos = call @signbit(%pos_tiny);
  require %s_neg == -1, "signbit on negative subnormal";
  require %s_pos == 0, "signbit on positive subnormal";
  ret 0;
}

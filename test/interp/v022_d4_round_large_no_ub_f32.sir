// EXPECT: PASS
// SPEC v0.2.2 §12.6 D.4 — integral rounding of a large value is never UB:
// every f32 with magnitude >= 2^23 is already integral, so floor/ceil/trunc
// are the identity and cannot overflow.  Confirms the "no UB" claim at the
// representable extreme.
intrinsic @floor(%x: f32) : f32;
intrinsic @ceil(%x: f32) : f32;
intrinsic @trunc(%x: f32) : f32;
fun @main() : i32 {
  let mut %r: f32 = 0.0;
  let %big: f32 = 16777216.0;   // 2^24, exactly integral in f32
^entry:
  %r = call @floor(%big);
  require %r == %big, "floor(2^24) == 2^24";
  %r = call @ceil(%big);
  require %r == %big, "ceil(2^24) == 2^24";
  %r = call @trunc(%big);
  require %r == %big, "trunc(2^24) == 2^24";
  ret 0;
}

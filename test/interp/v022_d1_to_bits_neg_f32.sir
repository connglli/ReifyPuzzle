// EXPECT: PASS
// SPEC v0.2.2 §12.6 @to_bits at f32 — -1.0f bit pattern is 0xBF800000.
// As signed i32 that is -1082130432.
intrinsic @to_bits(%x: f32) : i32;
fun @main() : i32 {
  let mut %r: i32 = 0;
^entry:
  %r = call @to_bits(-1.0);
  require %r == -1082130432, "to_bits(-1.0f) == 0xBF800000 (signed)";
  ret 0;
}

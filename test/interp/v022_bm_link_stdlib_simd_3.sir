// EXPECT: PASS
// EXPECT_RC: 10
// SPEC v0.2.2 §11.1
// INTERP_ARGS: -I test/lib/std/simd
// COMPILER_ARGS: -I test/lib/std/simd
// Intention: Uses stdlib reduce_add_4_i32 (vector) + local helper.
decl @reduce_add_4_i32(%v: <4> i32) : i32;

fun @bm_local_clip(%x: i32, %hi: i32) : i32 {
  let mut %y: i32 = 0;
^entry:
  br %x > %hi, ^cap, ^pass;
^cap:
  ret %hi;
^pass:
  br %x < 0, ^z, ^k;
^z:
  ret 0;
^k:
  ret %x;
}

fun @main() : i32 {
  let mut %v: <4> i32 = {1, 2, 3, 4};
  let mut %sum: i32 = 0;
  let mut %out: i32 = 0;
  let %hi: i32 = 100;
^entry:
  %sum = call @reduce_add_4_i32(%v);
  %out = call @bm_local_clip(%sum, %hi);
  br %out == %sum, ^eq, ^ne;
^eq:
  ret %out;
^ne:
  ret 0;
}

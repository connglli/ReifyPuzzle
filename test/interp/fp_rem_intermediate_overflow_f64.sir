// EXPECT: FAIL:UndefinedBehavior
// Spec §2.9 encodes `%` as
//   fp.sub(x, fp.mul(fp.roundToIntegral[RTZ](fp.div[RNE](x, y)), y))
// where the inner fp.div is subject to §7.4 rule 6 (FP overflow → UB).
// Here x/y = 1e600, which overflows f64 (max ≈ 1.8e308). The path is
// UB even though libm fmod(x, y) would return a finite value.
fun @main() : f64 {
  let %x: f64 = 1.0e300;
  let %y: f64 = 1.0e-300;
  let mut %r: f64 = 0.0;
^entry:
  %r = %x % %y;
  ret %r;
}

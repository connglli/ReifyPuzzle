// EXPECT: PASS
// SKIP: COMPILER
// Intention: Test cast from f64 to signed 64-bit integer (i64).
// Purpose: Verify that casting f64 to i64 truncates the fractional part towards zero using exactly representable inputs.
// Test f64 to i64 cast with truncation toward zero.
// 9007199254740990.5 as i64 -> 9007199254740990.
// -9007199254740990.5 as i64 -> -9007199254740990.
fun @main() : i32 {
  let %a1: f64 = 9007199254740990.5;
  let %a2: f64 = -9007199254740990.5;
  let %expected1: i64 = 9007199254740990;
  let %expected2: i64 = -9007199254740990;
  let mut %r1: i64 = 0;
  let mut %r2: i64 = 0;
^entry:
  %r1 = %a1 as i64;
  %r2 = %a2 as i64;
  require %r1 == %expected1, "9007199254740990.5 as i64 == 9007199254740990";
  require %r2 == %expected2, "-9007199254740990.5 as i64 == -9007199254740990";
  ret 0;
}

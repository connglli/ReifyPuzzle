// EXPECT: PASS
// SPEC §6.4 (after this fix): conditional branches treat an i1 as
// "non-zero is true".  Verify that flipping the storage to {0, -1}
// still routes `br <cond>` to the correct successor for both
// values.  We branch on `%cond != 0`, which is the canonical way
// RefractIR forms a boolean condition (the i1 holds 0 or -1; `!= 0`
// is true on -1 and false on 0).
intrinsic @signbit(%x: f64) : i1;
fun @main() : i32 {
  let mut %cond_true: i1 = 0;
  let mut %cond_false: i1 = 0;
^entry:
  %cond_true = call @signbit(-3.0);   // true
  %cond_false = call @signbit(3.0);   // false
  br %cond_true != 0, ^bt, ^bf;
^bt:
  br %cond_false != 0, ^miss_f, ^ok;
^bf:
  br ^fail;                            // br on true sent us to bf — wrong edge
^miss_f:
  br ^fail;                            // br on false took true edge — wrong
^ok:
  ret 0;
^fail:
  require 0 == 1, "br took the wrong edge for i1 cond";
  ret 0;
}

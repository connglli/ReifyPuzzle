// EXPECT: PASS
// REGRESSION: @is_pow2 over i1 under the v0.2.2 *signed* iN convention.
// SPEC v0.2.2 §12.4: @is_pow2(x) returns true iff x is a positive power
// of 2.
// SPEC v0.2.2 §6.4 / §6.12: i1 is a signed 1-bit integer; its only
// representable values are 0 (false) and -1 (true).  Neither is a
// positive power of 2, so @is_pow2(x: i1) must return false (0) for
// every legal i1 input.
//
// This regression specifically guards against a return to the previous
// (incorrect) "i1 is unsigned 0/1" convention, where @is_pow2(1) would
// have spuriously returned true.  Under that misreading the literal `1`
// passed as an i1 would be accepted (instead of being rejected by the
// signed-range typecheck), and the bit-1 input would be classified as
// a positive power of 2.
intrinsic @is_pow2(%x: i1) : i1;
fun @main() : i32 {
  let mut %a: i1 = 0;
  let mut %b: i1 = 0;
  let %true_i1: i1 = -1;
  let %false_i1: i1 = 0;
^entry:
  %a = call @is_pow2(%false_i1);    // 0 is not a power of 2
  %b = call @is_pow2(%true_i1);     // -1 is not > 0
  br %a == 0, ^a_ok, ^bad;
^a_ok:
  br %b == 0, ^both_ok, ^bad;
^both_ok:
  ret 0;
^bad:
  ret 1;
}

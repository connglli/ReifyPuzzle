fun @main() : i32 {
  let mut %a0: [1] ptr i8 = {undef};
  let mut %pp: ptr ptr i8 = undef;
  let mut %p: ptr i8 = undef;
^entry:
  %pp = addr %a0[0];
  %p = load %pp;
  ret 0;

// EXPECT: FAIL
// SPEC v0.2.2 §7.6 rule 21 - per-lane div0 in callee
fun @bad_div(%a: <4> i32, %b: <4> i32) : <4> i32 {
  let mut %r: <4> i32 = { 0, 0, 0, 0 };
^entry:
  %r = %a / %b;
  ret %r;
}
fun @main() : i32 {
  let mut %a: <4> i32 = { 10, 20, 30, 40 };
  let mut %b: <4> i32 = { 1, 0, 3, 4 }; // lane 1 is 0
  let mut %r: <4> i32 = { 0, 0, 0, 0 };
^entry:
  %r = call @bad_div(%a, %b);
  ret %r[0];
}

// EXPECT: PASS
// SKIP: WASM
// [v0.2.2] @crc32_update has two convenient identities the interpreter
// must preserve verbatim:
//   1. update(state=0, val=0) == 0 at every supported val width — every
//      byte is 0, every tab[0] lookup is 0, every shift-xor leaves the
//      state at 0.
//   2. update(s, 0) at i8 is `s >> 8` because tab[(s ^ 0) & 0xFF] is
//      tab[s & 0xFF]; for s == 0 this collapses to 0.
// These hold regardless of which iN overload is picked, which is the
// cheapest possible smoke test for the per-width dispatch.

intrinsic @crc32_update(%state: i32, %val: i8) : i32;
intrinsic @crc32_update(%state: i32, %val: i16) : i32;
intrinsic @crc32_update(%state: i32, %val: i32) : i32;
intrinsic @crc32_update(%state: i32, %val: i64) : i32;

fun @main() : i32 {
  let mut %s: i32 = 1;
  let %zero8: i8 = 0;
  let %zero16: i16 = 0;
  let %zero32: i32 = 0;
  let %zero64: i64 = 0;
^entry:
  %s = call @crc32_update(0, %zero8);
  require %s == 0, "update(0, 0:i8) == 0";

  %s = call @crc32_update(0, %zero16);
  require %s == 0, "update(0, 0:i16) == 0";

  %s = call @crc32_update(0, %zero32);
  require %s == 0, "update(0, 0:i32) == 0";

  %s = call @crc32_update(0, %zero64);
  require %s == 0, "update(0, 0:i64) == 0";

  ret 0;
}

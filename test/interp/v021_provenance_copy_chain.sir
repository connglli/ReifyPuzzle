// EXPECT: PASS
// SOLVER_ARGS: --main @main --path '^entry'
// SKIP: COMPILER

// Provenance propagation through pointer copy chain.
// addr %arr[0] → %p1 → %p2 → %p3. Each copy preserves provenance,
// so %p3 + 1 stays within the array and the load succeeds.
fun @main() : i32 {
  let mut %arr: [4] i32 = {10, 20, 30, 40};
  let mut %p1: ptr i32 = null;
  let mut %p2: ptr i32 = null;
  let mut %p3: ptr i32 = null;
  let mut %val: i32 = 0;
^entry:
  %p1 = addr %arr[0];
  %p2 = %p1;
  %p3 = %p2;
  %p3 = %p3 + 1;
  %val = load %p3;
  require %val == 20, "p3 should read arr[1]";
  ret 0;
}

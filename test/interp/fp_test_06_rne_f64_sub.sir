// EXPECT: PASS
// SKIP: COMPILER
// Intention: Test Round-to-Nearest-Ties-to-Even (RNE) rounding mode for f64 subtraction.
// Purpose: Verify that subtracting f64 values that yield a result halfway between two representable values rounds to the even LSB.
// Test Round-to-Nearest-Ties-to-Even (RNE) for f64 subtraction.
// 9007199254740996.0 (2^53 + 4) and 1.0 are representable in f64.
// 9007199254740996.0 - 1.0 = 9007199254740995.0, which is halfway between 9007199254740994.0 and 9007199254740996.0.
// RNE rounds to the even LSB: 9007199254740996.0.
// 9007199254740996.0 - 3.0 = 9007199254740993.0, which is halfway between 9007199254740992.0 and 9007199254740994.0.
// RNE rounds to the even LSB: 9007199254740992.0.
fun @main() : i32 {
  let %a: f64 = 9007199254740996.0;
  let %one: f64 = 1.0;
  let %three: f64 = 3.0;
  let %expected1: f64 = 9007199254740996.0;
  let %expected2: f64 = 9007199254740992.0;
  let mut %r1: f64 = 0.0;
  let mut %r2: f64 = 0.0;
^entry:
  %r1 = %a - %one;
  %r2 = %a - %three;
  require %r1 == %expected1, "2^53 + 4.0 - 1.0 rounds to 2^53 + 4.0";
  require %r2 == %expected2, "2^53 + 4.0 - 3.0 rounds to 2^53";
  ret 0;
}

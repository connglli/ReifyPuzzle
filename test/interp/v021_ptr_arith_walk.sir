// EXPECT: PASS
// Walk a pointer through an array via `ptr + 1`, summing values along the way.
fun @main() : i32 {
  let mut %arr: [4] i32 = {10, 20, 30, 40};
  let mut %p: ptr i32 = null;
  let %one: i32 = 1;
  let mut %acc: i32 = 0;
^entry:
  %p = addr %arr[0];
  %acc = %acc + load %p;
  %p = %p + %one;
  %acc = %acc + load %p;
  %p = %p + %one;
  %acc = %acc + load %p;
  %p = %p + %one;
  %acc = %acc + load %p;
  require %acc == 100, "sum of [10,20,30,40] is 100";
  ret %acc;
}

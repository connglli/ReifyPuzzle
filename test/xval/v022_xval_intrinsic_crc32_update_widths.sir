// EXPECT: PASS
// EXPECT_RC: 1150244089
// SKIP: WASM
// [v0.2.2] Cross-validate @crc32_update across all four val widths
// (i8 / i16 / i32 / i64) by chaining one update at each width into a
// single state. symiri and the compiled C lowering must agree
// byte-for-byte on the final i32 state. The reference 1150244089
// was computed by a Python reimplementation of the same recurrence.

intrinsic @crc32_update(%state: i32, %val: i8) : i32;
intrinsic @crc32_update(%state: i32, %val: i16) : i32;
intrinsic @crc32_update(%state: i32, %val: i32) : i32;
intrinsic @crc32_update(%state: i32, %val: i64) : i32;

fun @main() : i32 {
  let mut %s: i32 = 0;
  let %v8: i8 = 127;
  let %v16: i16 = 4660;
  let %v32: i32 = 305419896;
  let %v64: i64 = 81985529216486895;
^entry:
  %s = call @crc32_update(%s, %v8);
  %s = call @crc32_update(%s, %v16);
  %s = call @crc32_update(%s, %v32);
  %s = call @crc32_update(%s, %v64);
  ret %s;
}

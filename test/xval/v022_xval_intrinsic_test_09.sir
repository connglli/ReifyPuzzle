// Intention: Test @parity, @bswap, @bitreverse intrinsics on i32 under a Zig-Zag Crossover Loop CFG structure.
// EXPECT: PASS
// EXPECT_RC: 1
intrinsic @parity(%x: i32) : i1;
intrinsic @bswap(%x: i32) : i32;
intrinsic @bitreverse(%x: i32) : i32;

fun @my_func(%x: i32, %y: i32) : i32 {
  let mut %a: i32 = 0;
  let mut %b: i32 = 0;
  let mut %c: i1 = 0;
^entry:
  %a = call @bitreverse(%x);
  %b = call @bswap(%y);
  %c = call @parity(%x);
  br %a > %y, ^b1, ^b2;
^b1:
  %a = %a + 1;
  %b = %b - 1;
  br %a > %b, ^b3, ^b4;
^b2:
  %a = %a + 2;
  %b = %b - 2;
  br %c == 0, ^b3, ^b4;
^b3:
  %a = %a + 3;
  %b = %b - 3;
  br %a > %b, ^entry, ^entry;
^b4:
  %a = %a + 4;
  %b = %b - 4;
  br %a > %b, ^entry, ^entry;
}

fun @main() : i32 {
  let mut %x: i32 = 0;
  let mut %y: i32 = 0;
  let mut %r: i32 = 0;
  let mut %i: i32 = 0;
  let mut %p: i1 = 0;
^entry:
  %x = 0x01020304;
  %y = 2;
  %r = call @bswap(%x);
  br %i < 2, ^b1, ^exit;
^b1:
  %x = call @bitreverse(%x);
  br %x > 0, ^b3, ^b2;
^b2:
  %x = %x + 20;
  br %x > 0, ^b4, ^exit;
^b3:
  %p = call @parity(%r);
  %i = %i + 1;
  br %p == -1, ^b2, ^b4;
^b4:
  %x = %x - 549470330;
  %y = 4;
  br %x > %y, ^entry, ^entry;
^exit:
  %r = %x - %y;
  %r = %r - 16909057;
  ret %r;
}

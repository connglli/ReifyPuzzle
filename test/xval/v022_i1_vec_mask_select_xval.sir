// EXPECT: PASS
// EXPECT_RC: 0
// SPEC §2.11 + §6.3: cross-validate vector cmp producing <4> i1 mask
// and mask-based select.  Verifies that the compiled C / WASM backends
// produce the same lane values as the interpreter for vector cmp and
// mask select under the signed i1 convention.
fun @main() : i32 {
  let mut %a: <4> i32 = {5, 15, 25, 35};
  let mut %b: <4> i32 = {10, 10, 10, 10};
  let mut %mask: <4> i1 = {0, 0, 0, 0};
  let mut %res: <4> i32 = {0, 0, 0, 0};
  let mut %acc: i32 = 0;
^entry:
  // cmp < %a, %b → {true, false, false, false} = {-1, 0, 0, 0}
  %mask = cmp < %a, %b;

  // select: where mask true pick %a, else %b
  // → {5, 10, 10, 10}
  %res = select %mask, %a, %b;

  %acc = %res[0];         // 5
  %acc = %acc + %res[1];  // 5 + 10 = 15
  %acc = %acc + %res[2];  // 15 + 10 = 25
  %acc = %acc + %res[3];  // 25 + 10 = 35

  // Expected: 35 - 35 = 0
  %acc = %acc - 35;
  ret %acc;
}

// Intention: Test UB boundary conditions (extreme valid values) on i32 under a Skip-Level Branch CFG structure.
// EXPECT: PASS
// EXPECT_RC: 83
intrinsic @abs(%x: i32) : i32;
intrinsic @clz(%x: i32) : i32;
intrinsic @ctz(%x: i32) : i32;
intrinsic @abs_diff(%a: i32, %b: i32) : i32;
intrinsic @clamp(%v: i32, %lo: i32, %hi: i32) : i32;
intrinsic @rotl(%x: i32, %n: i32) : i32;
intrinsic @rotr(%x: i32, %n: i32) : i32;
intrinsic @ilog2(%x: i32) : i32;

fun @my_func(%x: i32, %y: i32) : i32 {
  let mut %a: i32 = 0;
  let mut %b: i32 = 0;
  let mut %c: i32 = 0;
^entry:
  %a = call @abs(%x);
  %b = call @clz(%y);
  %c = call @ctz(%x);
  br %a > %y, ^b1, ^b3;
^b1:
  %a = %a + 1;
  %b = %b - 1;
  br %a > %b, ^b2, ^entry;
^b2:
  %a = %a + 2;
  br %b > %a, ^b3, ^entry;
^b3:
  %a = %a + 3;
  %b = %b - 3;
  %c = %c + %a;
  br %c > %b, ^b4, ^b4;
^b4:
  %a = %a + 4;
  %b = %b - 4;
  %c = %c + %b;
  br %a > %c, ^entry, ^entry;
}

fun @main() : i32 {
  let mut %res: i32 = 0;
  let mut %r1: i32 = 0;
  let mut %c1: i32 = 0;
  let mut %cl: i32 = 0;
  let mut %rot1: i32 = 0;
  let mut %rot2: i32 = 0;
  let mut %il: i32 = 0;
^entry:
  %r1 = call @abs(-2147483647); // Boundary: INT_MIN_32 + 1 (UB is -2147483648)
  br %r1 > 0, ^b1, ^b3;
^b1:
  %c1 = call @clz(1); // Boundary: min non-zero value 1 (UB is 0)
  br %c1 > 0, ^b2, ^exit;
^b2:
  %cl = call @clamp(5, 10, 10); // Boundary: lo == hi (UB when lo > hi)
  br %cl > 0, ^b3, ^exit;
^b3:
  br %r1 > 0, ^b4, ^exit;
^b4:
  br %r1 > 0, ^exit, ^exit;
^exit:
  %rot1 = call @rotl(1, 31); // Boundary: shift amount N-1 = 31 (UB when >= 32 or < 0)
  %rot1 = -0x80000000 ^ %rot1;
  %rot2 = call @rotr(1, 31); // Boundary: shift amount N-1 = 31 (UB when >= 32 or < 0)
  %il = call @ilog2(1); // Boundary: minimum positive value 1 (UB when <= 0)
  %res = %c1 + %cl;
  %res = %res + %rot1;
  %res = %res + %rot2;
  %res = %res + %il;
  %res = %res + 40;
  ret %res;
}

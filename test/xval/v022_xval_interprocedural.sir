// EXPECT: PASS
// EXPECT_RC: 42
// Intention: SPEC v0.2.2 §6.10 - Interprocedural cross-validation.
// Verifies that function calls work correctly across interp/compiler.

fun @add(%a: i32, %b: i32) : i32 {
^entry:
  ret %a + %b;
}

fun @mul(%a: i32, %b: i32) : i32 {
^entry:
  ret %a * %b;
}

fun @main() : i32 {
  let mut %x: i32 = 10;
  let mut %y: i32 = 2;
  let mut %z: i32 = 0;
^entry:
  %z = call @add(%x, %y); // 12
  %z = call @mul(%z, 3);   // 36
  %z = call @add(%z, 6);   // 42
  ret %z;
}

// EXPECT: PASS
// EXPECT_RC: 0
// SPEC §6.4 + §6.12: cross-validate i1 ptr store/load round trip.
// Stores i1 values (-1 and 0) through ptr i1, loads them back,
// and widens to i32 for return.  Both tools must agree on the
// memory representation.
fun @main() : i32 {
  let mut %flag: i1 = 0;
  let mut %p: ptr i1 = null;
  let mut %loaded: i1 = 0;
  let mut %acc: i32 = 0;
^entry:
  %p = addr %flag;

  // Store true (-1), load, widen
  store %p, -1;
  %loaded = load %p;
  %acc = %loaded as i32;          // -1

  // Store false (0), load, widen
  store %p, 0;
  %loaded = load %p;
  %acc = %acc + %loaded as i32;   // -1 + 0 = -1

  // Store true again
  store %p, -1;
  %loaded = load %p;
  %acc = %acc + %loaded as i32;   // -1 + (-1) = -2

  // Balance
  %acc = %acc + 2;
  ret %acc;
}

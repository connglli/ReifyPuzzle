// EXPECT: PASS
// EXPECT_RC: 10
// Intention: SPEC v0.2.2 §6.10, §6.2.2 - Cross-validation of vector parameters.
// Verifies that vectors can be passed to functions and returned.

fun @sum_vec(%v: <4> i32) : i32 {
  let mut %s: i32 = 0;
^entry:
  %s = %v[0] + %v[1];
  %s = %s + %v[2];
  %s = %s + %v[3];
  ret %s;
}

fun @main() : i32 {
  let mut %v: <4> i32 = { 1, 2, 3, 4 };
  let mut %res: i32 = 0;
^entry:
  %res = call @sum_vec(%v);
  ret %res;
}

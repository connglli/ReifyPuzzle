// EXPECT: PASS
// EXPECT_RC: 650981917
// [v0.2.2] Cross-validate @crc32_update: a five-step chain over 1..5 at
// i32 must produce the same signed-i32 state in both symiri and the
// compiled C lowering. Reference value 650981917 was independently
// computed from the reflected-0xEDB88320 polynomial recurrence.

intrinsic @crc32_update(%state: i32, %val: i32) : i32;

fun @main() : i32 {
  let mut %s: i32 = 0;
^entry:
  %s = call @crc32_update(%s, 1);
  %s = call @crc32_update(%s, 2);
  %s = call @crc32_update(%s, 3);
  %s = call @crc32_update(%s, 4);
  %s = call @crc32_update(%s, 5);
  ret %s;
}

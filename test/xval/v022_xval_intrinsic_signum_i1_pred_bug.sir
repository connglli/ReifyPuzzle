// EXPECT: PASS
// EXPECT_RC: 0
// Cross-validate @signum at i1 between interpreter and compiled C / WASM
// under the v0.2.2 *signed* iN convention.
//
// SPEC v0.2.2 §12.3 @signum(x): returns -1 (x<0), 0 (x=0), 1 (x>0).
// SPEC v0.2.2 §6.4 / §6.12: i1 is signed; representable values are 0
// (false) and -1 (true).  So for i1:
//   @signum(0)  = 0   (zero stays zero)
//   @signum(-1) = -1  (negative input maps to the only representable
//                     negative in i1)
//
// Regression guard against the old "i1 is unsigned 0/1" convention,
// where @signum(1) would return 1 — a value that's out of i1's signed
// range and would either be rejected by the typechecker or diverge
// between interp and compiled output.
intrinsic @signum(%x: i1) : i1;
fun @main() : i32 {
  let mut %a: i1 = 0;
  let mut %b: i1 = 0;
  let %true_i1: i1 = -1;
  let %false_i1: i1 = 0;
^entry:
  %a = call @signum(%true_i1);    // -1 stays -1
  %b = call @signum(%false_i1);   // 0 stays 0
  br %a == -1, ^a_ok, ^bad;
^a_ok:
  br %b == 0, ^b_ok, ^bad;
^b_ok:
  ret 0;
^bad:
  ret 1;
}

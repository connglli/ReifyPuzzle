// EXPECT: PASS
// EXPECT_RC: 0
// Cross-validate is_pow2 at i1 between interpreter and compiled C/WASM.
//
// Guarded by EXPECT_RC: 0 — if either the interpreter or backend reverts
// the i1 unsigned convention (argSint / makeSextN), the program takes the
// ^bad path, returns 1, and EXPECT_RC fails.
//
// SPEC v0.2.2 §12.4 is_pow2: returns true iff x is a positive power of 2.
// SPEC v0.2.2 §10.4: i1 values are 0 (false) and 1 (true).
intrinsic @is_pow2(%x: i1) : i1;
fun @main() : i32 {
  let mut %a: i1 = 0;
  let %one: i1 = 1;
  let %zero: i32 = 0;
^entry:
  %a = call @is_pow2(1);
  br %a == %one, ^a_ok, ^bad;
^a_ok:
  ret %zero;
^bad:
  ret 1;
}

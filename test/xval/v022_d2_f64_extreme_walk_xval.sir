// Intention: cross-validate D.1+D.2 ops at three f64 extremes —
// (a) max finite, (b) smallest positive normal, (c) smallest positive
// subnormal — and at one signed-zero point.  For each extreme we
// classify, flip the sign, and round-trip the bit pattern.  Seven
// intrinsics, 19 basic blocks, 14 chained correctness branches —
// any single per-extreme step misbehaving falls into ^fail and the
// encoded return diverges from EXPECT_RC.
// EXPECT: PASS
// EXPECT_RC: 257
intrinsic @from_bits(%x: i64) : f64;
intrinsic @to_bits(%x: f64) : i64;
intrinsic @fneg(%x: f64) : f64;
intrinsic @copysign(%x: f64, %y: f64) : f64;
intrinsic @signbit(%x: f64) : i1;
intrinsic @is_normal(%x: f64) : i1;
intrinsic @is_subnormal(%x: f64) : i1;

fun @main() : i32 {
  let mut %max_fin: f64 = 0.0;
  let mut %min_norm: f64 = 0.0;
  let mut %min_sub: f64 = 0.0;
  let mut %neg_max: f64 = 0.0;
  let mut %back_pos: f64 = 0.0;
  let mut %b_back: i64 = 0;
  let mut %t: i1 = 0;
  let mut %r: i32 = 0;
^entry:
  %max_fin = call @from_bits(9218868437227405311);   // 0x7FEFFFFFFFFFFFFF
  %min_norm = call @from_bits(4503599627370496);     // 0x0010000000000000
  %min_sub = call @from_bits(1);                     // 0x0000000000000001
  br ^check_max;
^check_max:
  %t = call @is_normal(%max_fin);
  br %t == -1, ^cm2, ^fail;
^cm2:
  %t = call @is_subnormal(%max_fin);
  br %t == 0, ^cm3, ^fail;
^cm3:
  %t = call @signbit(%max_fin);
  br %t == 0, ^check_min_norm, ^fail;
^check_min_norm:
  %t = call @is_normal(%min_norm);
  br %t == -1, ^cmn2, ^fail;
^cmn2:
  %t = call @is_subnormal(%min_norm);
  br %t == 0, ^check_min_sub, ^fail;
^check_min_sub:
  %t = call @is_normal(%min_sub);
  br %t == 0, ^cmis2, ^fail;
^cmis2:
  %t = call @is_subnormal(%min_sub);
  br %t == -1, ^check_neg_max, ^fail;
^check_neg_max:
  // Flip max_finite via @fneg and verify classification preserved,
  // signbit flipped, then round-trip the bit pattern.
  %neg_max = call @fneg(%max_fin);
  %t = call @is_normal(%neg_max);
  br %t == -1, ^cnm2, ^fail;
^cnm2:
  %t = call @signbit(%neg_max);
  br %t == -1, ^cnm3, ^fail;
^cnm3:
  // @copysign restores positive sign.
  %back_pos = call @copysign(%neg_max, 1.0);
  %t = call @signbit(%back_pos);
  br %t == 0, ^cnm4, ^fail;
^cnm4:
  // Bit-exact round-trip of max_fin through to_bits.
  %b_back = call @to_bits(%back_pos);
  br %b_back == 9218868437227405311, ^check_neg_sub, ^fail;
^check_neg_sub:
  // Flip min_sub and verify classification preserved.
  %neg_max = call @fneg(%min_sub);
  %t = call @is_subnormal(%neg_max);
  br %t == -1, ^cns2, ^fail;
^cns2:
  %t = call @signbit(%neg_max);
  br %t == -1, ^success, ^fail;
^success:
  %r = 257;
  br ^exit;
^fail:
  %r = 0;
  br ^exit;
^exit:
  ret %r;
}

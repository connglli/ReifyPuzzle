// EXPECT: PASS
// EXPECT_RC: 30
// [v0.2.2] Regression: loading through a pointer to an array-typed field of
// an array-of-structs element (`%a[1].f1[0]` where `a: [2] @S`, `f1: [2]
// i32`). The interpreter flattened array-of-struct elements into the heap one
// nesting level deep, storing an aggregate-typed field (`f1`) as a single
// whole-array heap entry rather than per-element scalars. A `load` of the
// element address then returned the whole `[2] i32` array, which downstream
// arithmetic rejected ("Expr ops only on same scalar kinds"). The fix
// flattens every aggregate field/element to per-leaf heap cells. Cross-
// validated interp vs C.
struct @S {
  f0: i16;
  f1: [2] i32;
}

fun @main() : i32 {
  let mut %a: [2] @S = {{1, {10, 20}}, {2, {30, 40}}};
  let mut %p: ptr i32 = undef;
  let mut %r: i32 = 0;
^entry:
  %p = addr %a[1].f1[0];
  %r = load %p;
  ret %r;
}

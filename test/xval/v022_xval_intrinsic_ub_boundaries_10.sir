// Intention: Test UB boundary conditions (extreme valid values) on i16 under a Zig-Zag Crossover Loop CFG structure.
// EXPECT: PASS
// EXPECT_RC: 8
intrinsic @abs(%x: i16) : i16;
intrinsic @clz(%x: i16) : i16;
intrinsic @ctz(%x: i16) : i16;
intrinsic @abs_diff(%a: i16, %b: i16) : i16;
intrinsic @clamp(%v: i16, %lo: i16, %hi: i16) : i16;
intrinsic @rotl(%x: i16, %n: i16) : i16;
intrinsic @rotr(%x: i16, %n: i16) : i16;
intrinsic @ilog2(%x: i16) : i16;

fun @my_func(%x: i16, %y: i16) : i16 {
  let mut %a: i16 = 0;
  let mut %b: i16 = 0;
  let mut %c: i16 = 0;
^entry:
  %a = call @abs(%x);
  %b = call @clz(%y);
  %c = call @ctz(%x);
  br %a > %y, ^b1, ^b2;
^b1:
  %a = %a + 1;
  %b = %b - 1;
  br %a > %b, ^b3, ^b4;
^b2:
  %a = %a + 2;
  %b = %b - 2;
  br %a > %b, ^b3, ^b4;
^b3:
  %a = %a + 3;
  %b = %b - 3;
  br %a > %b, ^entry, ^entry;
^b4:
  %a = %a + 4;
  %b = %b - 4;
  br %a > %b, ^entry, ^entry;
}

fun @main() : i16 {
  let mut %res: i16 = 0;
  let mut %r1: i16 = 0;
  let mut %c1: i16 = 0;
  let mut %t1: i16 = 0;
  let mut %cl: i16 = 0;
  let mut %rot1: i16 = 0;
  let mut %rot2: i16 = 0;
  let mut %il: i16 = 0;
  let mut %i: i16 = 0;
^entry:
  %r1 = call @abs(-32767); // Boundary: INT_MIN_16 + 1 (UB is -32768)
  br %i < 2, ^b1, ^exit;
^b1:
  %c1 = call @clz(1); // Boundary: min non-zero value 1 (UB is 0)
  br %c1 > 0, ^b3, ^b2;
^b2:
  %t1 = call @ctz(1);
  br %t1 > 0, ^b4, ^exit;
^b3:
  %cl = call @clamp(5, 10, 10); // Boundary: lo == hi (UB when lo > hi)
  %i = %i + 1;
  br %i == 1, ^b2, ^b4;
^b4:
  br %i < 10, ^entry, ^entry;
^exit:
  %rot1 = call @rotl(1, 15); // Boundary: shift amount N-1 = 15 (UB when >= 16 or < 0)
  %rot1 = 0x8000 ^ %rot1;
  %rot2 = call @rotr(1, 15); // Boundary: shift amount N-1 = 15 (UB when >= 16 or < 0)
  %il = call @ilog2(1); // Boundary: minimum positive value 1 (UB when <= 0)
  %res = %c1 + %cl;
  %res = %res + %rot1;
  %res = %res + %rot2;
  %res = %res + %il;
  %res = %res - 19;
  ret %res;
}

// Intention: Test UB boundary conditions (extreme valid values) on i32 under a Binary Tree CFG structure.
// EXPECT: PASS
// EXPECT_RC: -1073741723
intrinsic @abs(%x: i32) : i32;
intrinsic @clz(%x: i32) : i32;
intrinsic @ctz(%x: i32) : i32;
intrinsic @abs_diff(%a: i32, %b: i32) : i32;
intrinsic @clamp(%v: i32, %lo: i32, %hi: i32) : i32;
intrinsic @rotl(%x: i32, %n: i32) : i32;
intrinsic @rotr(%x: i32, %n: i32) : i32;
intrinsic @ilog2(%x: i32) : i32;

fun @my_func(%x: i32, %y: i32) : i32 {
  let mut %a: i32 = 0;
  let mut %b: i32 = 0;
  let mut %c: i32 = 0;
^entry:
  %a = call @abs(%x);
  %b = call @clz(%y);
  %c = call @ctz(%x);
  br %a > %y, ^b1, ^b2;
^b1:
  %a = %a + 1;
  %b = %b - 1;
  br %a > %b, ^b3, ^b4;
^b2:
  %a = %a + 2;
  %b = %b - 2;
  br %a > %b, ^b3, ^b4;
^b3:
  %a = %a + 3;
  %b = %b - 3;
  br %a > %b, ^entry, ^entry;
^b4:
  %a = %a + 4;
  %b = %b - 4;
  br %a > %b, ^entry, ^entry;
}

fun @main() : i32 {
  let mut %res: i32 = 0;
  let mut %r1: i32 = 0;
  let mut %c1: i32 = 0;
  let mut %t1: i32 = 0;
  let mut %d1: i32 = 0;
  let mut %cl: i32 = 0;
  let mut %rot1: i32 = 0;
  let mut %rot2: i32 = 0;
  let mut %il: i32 = 0;
^entry:
  %r1 = call @abs(-2147483647); // Boundary: INT_MIN_32 + 1 (UB is -2147483648)
  %c1 = call @clz(0x40000000);
  br %c1 > 0, ^b1, ^b2;
^b1:
  %t1 = call @ctz(0x40000000);
  br %t1 > 0, ^b3, ^b4;
^b2:
  br %t1 > 0, ^exit, ^exit;
^b3:
  %d1 = call @abs_diff(0, -2147483647); // Boundary: max difference INT_MAX_32
  %cl = call @clamp(-100, -100, -100); // Boundary: lo == hi (UB when lo > hi)
  br %d1 > 0, ^exit, ^exit;
^b4:
  br %d1 > 0, ^exit, ^exit;
^exit:
  %rot1 = call @rotl(0x7FFFFFFF, 31); // Boundary: shift amount N-1 = 31 (UB when >= 32 or < 0)
  %rot2 = call @rotr(0x7FFFFFFF, 31); // Boundary: shift amount N-1 = 31 (UB when >= 32 or < 0)
  %il = call @ilog2(2147483647); // Boundary: valid positive INT_MAX (UB when <= 0)
  %res = %c1 + %t1;
  %res = %res + %cl;
  %res = %res + %il;
  %res = %res + %rot1;
  %res = %res + %rot2;
  %res = %res + 143;
  ret %res;
}

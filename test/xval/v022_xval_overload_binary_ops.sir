// EXPECT: PASS
// EXPECT_RC: 7
// [v0.2.2] Test overload resolution where intrinsic calls are operands in complex expression chains.

intrinsic @abs(%x: i32) : i32;
intrinsic @abs(%x: i64) : i64;

fun @main() : i32 {
  let mut %x32: i32 = -3;
  let mut %y32: i32 = -5;
  let mut %x64: i64 = -3;
  let mut %y64: i64 = -5;
  let mut %res32: i32 = 0;
  let mut %res64: i64 = 0;
^entry:
  // abs(-3) + abs(-5) - 1 = 3 + 5 - 1 = 7 (i32)
  %res32 = call @abs(%x32) + call @abs(%y32) - 1;
  require %res32 == 7, "abs(-3) + abs(-5) - 1 == 7 (i32)";

  // abs(-3) + abs(-5) - 1 = 3 + 5 - 1 = 7 (i64)
  %res64 = call @abs(%x64) + call @abs(%y64) - 1;
  require %res64 == 7, "abs(-3) + abs(-5) - 1 == 7 (i64)";

  ret %res32;
}

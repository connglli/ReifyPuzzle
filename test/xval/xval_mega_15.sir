// EXPECT: PASS
// EXPECT_RC: 212
// INTERP_ARGS: -I test/lib/std/collections
// COMPILER_ARGS: -I test/lib/std/collections
// COMPILER_ARGS: -I test/lib/std/collections
// Intention: SPEC v0.2.2 - Mega xval test 15 (Arrays & Pointers)

intrinsic @abs(%x: i32) : i32;
intrinsic @min(%a: i32, %b: i32) : i32;
intrinsic @max(%a: i32, %b: i32) : i32;
intrinsic @clz(%x: i32) : i32;
intrinsic @ctz(%x: i32) : i32;
intrinsic @popcount(%x: i32) : i32;

decl @array_sum_4_i32(%p: ptr [4] i32) : i32;

fun @internal_modifier(%p: ptr [4] i32) : i32 {
  let mut %pi: ptr i32 = null;
  let mut %v: i32 = 0;
^entry:
  %pi = ptrindex %p, 0;
  %v = load %pi;
  %v = %v + 10;
  store %pi, %v;
  ret 0;
}

fun @main() : i32 {
  let mut %arr: [4] i32 = { 21, 40, 14, 5 };
  let mut %acc: i32 = 0;
  let mut %pa: ptr [4] i32 = null;
  let mut %r: i32 = 0;
  let mut %m1: i32 = 0;
  let mut %m2: i32 = 0;
  let mut %p1: i32 = 0;
  let %one: i32 = 1;
^entry:
  %pa = addr %arr;
  %r = call @internal_modifier(%pa);
  %acc = call @array_sum_4_i32(%pa);
  br %acc > 0, ^b1, ^b2;

^b1:
  %m1 = call @abs(%acc);
  %m2 = call @min(%m1, 100);
  %acc = %acc + %m2;
  br %acc > 0, ^b3, ^b4;

^b2:
  %m1 = call @max(%acc, 0);
  %acc = %acc + %m1;
  %acc = %acc + %one;
  br %acc > 0, ^b3, ^b4;

^b3:
  %p1 = call @popcount(%acc);
  %acc = %acc + %p1;
  %m1 = call @clz(15);
  %acc = %acc + %m1;
  br %one == %one, ^exit, ^exit;

^b4:
  %m1 = call @ctz(16);
  %acc = %acc + %m1;
  %acc = %acc + %one;
  %acc = %acc - %one;
  br %one == %one, ^exit, ^exit;

^exit:
  ret %acc;
}

// EXPECT: PASS
// EXPECT_RC: 109
// [v0.2.2] Regression: `addr` of a nested-array element on a single-element
// outer array. `%a: [1] [3] i16` and its sole `[3] i16` element occupy the
// same base address and the same 6-byte span, so the interpreter's
// object-resolution (findFieldOrStructObject) used to return the OUTER array
// (count 1) for the inner type, falsely rejecting `%a[0][2]` as an
// out-of-bounds element. The addr index also derived its element size/count
// from that wrong object, mis-computing the cell address. The fix resolves
// the inner object by type and advances the address from the static type, so
// `%a[0][2]` is the in-bounds i16 cell. Cross-validated interp vs compiled C.
fun @main() : i32 {
  let mut %a: [1] [3] i16 = {{10, 20, 30}};
  let mut %p: ptr i16 = undef;
  let mut %r: i32 = 0;
^entry:
  %p = addr %a[0][2];
  store %p, 99;
  %r = %a[0][0] as i32 + %a[0][2] as i32;
  ret %r;
}

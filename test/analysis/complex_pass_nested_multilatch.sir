// EXPECT: PASS
// COMPILER_ARGS: --require-reducible

// A loop nested inside another loop, where the inner loop has two latches
// (^inner_latch_1 and ^inner_latch_2) that both branch back to ^inner_head.
// This is fully reducible.
fun @main(): i32 {
    let mut %i: i32 = 0;
    let mut %j: i32 = 0;
    let mut %acc: i32 = 0;
^entry:
    br ^outer_head;

^outer_head:
    br %i < 10, ^inner_init, ^done;

^inner_init:
    %j = 0;
    br ^inner_head;

^inner_head:
    br %j < 10, ^inner_body, ^outer_latch;

^inner_body:
    %acc = %acc + %j;
    br %j < 5, ^inner_latch_1, ^inner_latch_2;

^inner_latch_1:
    %j = %j + 1;
    br ^inner_head;

^inner_latch_2:
    %j = %j + 2;
    br ^inner_head;

^outer_latch:
    %i = %i + 1;
    br ^outer_head;

^done:
    ret %acc;
}

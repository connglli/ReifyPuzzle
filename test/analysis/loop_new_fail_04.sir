// EXPECT: FAIL:StaticError
// COMPILER_ARGS: --require-reducible --dump-loops

// Fail 4: Cycle of three blocks with no unique header dominating all of them.
fun @main(): i32 {
    let mut %x: i32 = 0;
^entry:
    br %x < 5, ^a, ^b;
^a:
    br ^b;
^b:
    br ^c;
^c:
    br %x < 100, ^a, ^exit;
^exit:
    ret %x;
}

// EXPECT: FAIL:StaticError
// COMPILER_ARGS: --require-reducible --dump-loops

// Fail 7: Latch branches back to ^a, but ^a does not dominate ^latch.
fun @main(): i32 {
    let mut %x: i32 = 0;
^entry:
    br %x < 5, ^a, ^b;
^a:
    br ^latch;
^b:
    br ^latch;
^latch:
    %x = %x + 1;
    br %x < 100, ^a, ^exit;
^exit:
    ret %x;
}

// EXPECT: PASS
// COMPILER_ARGS: --require-reducible

// Reducible nested loops: every retreating edge targets a block that
// dominates its source, so the check accepts the program and symirc
// proceeds to normal C emission.
fun @main(): i32 {
    let mut %i: i32 = 0;
    let mut %j: i32 = 0;
    let mut %acc: i32 = 0;
^entry:
    br ^outer_head;

^outer_head:
    br %i < 10, ^inner_init, ^done;

^inner_init:
    %j = 0;
    br ^inner_head;

^inner_head:
    br %j < 10, ^inner_body, ^outer_latch;

^inner_body:
    %acc = %acc + %j;
    %j = %j + 1;
    br ^inner_head;

^outer_latch:
    %i = %i + 1;
    br ^outer_head;

^done:
    ret %acc;
}

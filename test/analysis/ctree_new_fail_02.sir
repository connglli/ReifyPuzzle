// EXPECT: FAIL:StaticError
// COMPILER_ARGS: --dump-control-tree

// Fail 2: Entry branches directly into the loop body (^body) bypassing the header (^head).
fun @main(): i32 {
    let mut %i: i32 = 0;
    let mut %acc: i32 = 0;
^entry:
    br %i < 5, ^body, ^head;
^head:
    br %i < 10, ^body, ^exit;
^body:
    %acc = %acc + %i;
    %i = %i + 1;
    br ^head;
^exit:
    ret %acc;
}

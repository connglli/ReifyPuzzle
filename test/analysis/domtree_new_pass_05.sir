// EXPECT: PASS
// COMPILER_ARGS: --dump-domtree

// Test 5: Nested loops.
fun @main(): i32 {
    let mut %i: i32 = 0;
    let mut %j: i32 = 0;
^entry:
    br ^outer_head;
^outer_head:
    br %i < 5, ^inner_init, ^exit;
^inner_init:
    %j = 0;
    br ^inner_head;
^inner_head:
    br %j < 5, ^inner_body, ^outer_latch;
^inner_body:
    %j = %j + 1;
    br ^inner_head;
^outer_latch:
    %i = %i + 1;
    br ^outer_head;
^exit:
    ret 0;
}

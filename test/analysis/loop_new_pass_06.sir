// EXPECT: PASS
// COMPILER_ARGS: --dump-loops

// Test 6: Sibling loops in sequence.
fun @main(): i32 {
    let mut %i: i32 = 0;
    let mut %j: i32 = 0;
^entry:
    br ^loop1_head;
^loop1_head:
    br %i < 5, ^loop1_body, ^loop2_head;
^loop1_body:
    %i = %i + 1;
    br ^loop1_head;
^loop2_head:
    br %j < 5, ^loop2_body, ^exit;
^loop2_body:
    %j = %j + 1;
    br ^loop2_head;
^exit:
    ret 0;
}

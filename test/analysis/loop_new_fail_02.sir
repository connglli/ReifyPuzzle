// EXPECT: FAIL:StaticError
// COMPILER_ARGS: --require-reducible --dump-loops

// Fail 2: Jumps from entry directly into the body bypassing the header.
fun @main(): i32 {
    let mut %i: i32 = 0;
    let mut %acc: i32 = 0;
^entry:
    br %i < 5, ^body, ^head;
^head:
    br %i < 10, ^body, ^exit;
^body:
    %acc = %acc + %i;
    %i = %i + 1;
    br ^head;
^exit:
    ret %acc;
}

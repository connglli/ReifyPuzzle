// EXPECT: PASS
// COMPILER_ARGS: --dump-loops

// Test 8: Sequential loops nested inside an outer loop.
fun @main(): i32 {
    let mut %i: i32 = 0;
    let mut %j: i32 = 0;
    let mut %k: i32 = 0;
^entry:
    br ^outer_head;
^outer_head:
    br %i < 5, ^inner1_init, ^exit;
^inner1_init:
    %j = 0;
    br ^inner1_head;
^inner1_head:
    br %j < 5, ^inner1_body, ^inner2_init;
^inner1_body:
    %j = %j + 1;
    br ^inner1_head;
^inner2_init:
    %k = 0;
    br ^inner2_head;
^inner2_head:
    br %k < 5, ^inner2_body, ^outer_latch;
^inner2_body:
    %k = %k + 1;
    br ^inner2_head;
^outer_latch:
    %i = %i + 1;
    br ^outer_head;
^exit:
    ret 0;
}

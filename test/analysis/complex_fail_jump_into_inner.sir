// EXPECT: FAIL:StaticError
// COMPILER_ARGS: --require-reducible

// A nested loop program where the entry block contains a branch that can jump
// directly into the innermost loop's body (^inner_body), bypassing both the
// outer loop header (^outer_head) and the inner loop header (^inner_head).
// This is irreducible.
fun @main(): i32 {
    let mut %i: i32 = 0;
    let mut %j: i32 = 0;
    let mut %acc: i32 = 0;
^entry:
    br %acc == 0, ^inner_body, ^outer_head;

^outer_head:
    br %i < 10, ^inner_init, ^exit;

^inner_init:
    %j = 0;
    br ^inner_head;

^inner_head:
    br %j < 10, ^inner_body, ^outer_latch;

^inner_body:
    %acc = %acc + %j;
    %j = %j + 1;
    br ^inner_head;

^outer_latch:
    %i = %i + 1;
    br ^outer_head;

^exit:
    ret %acc;
}

// EXPECT: FAIL:StaticError
// COMPILER_ARGS: --require-reducible

// A retreating edge where the target does not dominate the source.
// ^latch is reached from both ^a and ^b.
// Neither ^a nor ^b dominates ^latch.
// The edge ^latch -> ^a is a retreating edge (RPO of ^a < RPO of ^latch)
// but ^a does not dominate ^latch because ^latch can be reached via ^b.
fun @main(): i32 {
    let mut %x: i32 = 0;
^entry:
    br %x < 5, ^a, ^b;

^a:
    br ^latch;

^b:
    br ^latch;

^latch:
    %x = %x + 1;
    br %x < 100, ^a, ^exit;

^exit:
    ret %x;
}

// EXPECT: FAIL:UndefinedBehavior
// SKIP: INTERPRETER, COMPILER
// SOLVER_ARGS: --main @main --path '^entry'
//
// Intention: Expose the solver's lack of overshift checking on vector shifts.
// Exposes: Solver bug where overshift UB checks (shift amount >= bitwidth) are missing for vector shifts.
// Expected Behavior: Solver detects that shifting by >= 32 bits on i32 vector triggers UB, making path infeasible (UNSAT).
// Actual Behavior: Solver ignores the UB and solves it successfully (returns SAT).

fun @main() : i32 {
  let mut %v1: <4> i32 = {1, 0, 0, 0};
  let mut %v2: <4> i32 = {32, 0, 0, 0};
  let mut %res: <4> i32 = {0, 0, 0, 0};
^entry:
  // Shifting i32 lanes by 32 bits is overshift UB.
  %res = %v1 << %v2;
  ret 0;
}

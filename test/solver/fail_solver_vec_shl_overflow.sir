// EXPECT: FAIL:UndefinedBehavior
// SKIP: INTERPRETER, COMPILER
// SOLVER_ARGS: --main @main --path '^entry'
//
// Intention: Expose the solver's lack of signed overflow checking on vector shifts.
// Exposes: Solver bug where signed overflow UB checks are missing for vector shifts.
// Expected Behavior: Solver detects that shifting a negative signed integer or overflowing triggers UB, making path infeasible (UNSAT).
// Actual Behavior: Solver ignores the UB and solves it successfully (returns SAT).

fun @main() : i32 {
  let mut %v1: <4> i32 = {-1, 0, 0, 0};
  let mut %v2: <4> i32 = {1, 0, 0, 0};
  let mut %res: <4> i32 = {0, 0, 0, 0};
^entry:
  // Shifting a negative value (%v1[0] = -1) signed-left by 1 is UB.
  %res = %v1 << %v2;
  ret 0;
}

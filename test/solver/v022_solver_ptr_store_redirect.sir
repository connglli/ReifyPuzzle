// EXPECT: PASS
// SOLVER_ARGS: --main @main --path '^entry'
// [v0.2.2] Regression: a pointer-valued store that redirects %p (`store %pp,
// addr %v1`, where %pp points at %p) must carry the stored pointer's
// provenance into %p. Before the fix the store updated only %p's value, not
// its provenance, so the next `store %p, 42` bounds-checked the NEW address
// (&v1) against the STALE base (&v0) and the solver returned UNSAT for this
// trivially-satisfiable path. The concretized program is also run through the
// interpreter, which must agree (%v0 stays 0, %v1 becomes 42).
fun @main() : i32 {
  let mut %v0: i32 = 0;
  let mut %v1: i32 = 0;
  let mut %r: i32 = 0;
  let mut %p: ptr i32 = undef;
  let mut %pp: ptr ptr i32 = undef;
^entry:
  %p = addr %v0;
  %pp = addr %p;
  store %pp, addr %v1;
  store %p, 42;
  %r = %v0 + 1000 * %v1;
  ret %r;
}

// EXPECT: PASS
// SOLVER_ARGS: --path ^entry,^exit
// [v0.2.2] §12.6 D.3 — solver synthesizes a value for %?x such that
// @fmax(%?x, 2.0) == %?x.  Any model with %?x >= 2.0 satisfies it.
intrinsic @fmax(%x: f64, %y: f64) : f64;
fun @main() : f64 {
  sym %?x : value f64;
  let mut %r: f64 = 0.0;
^entry:
  %r = call @fmax(%?x, 2.0);
  require %r == %?x, "fmax(?x, 2.0) == ?x ⇒ ?x ≥ 2.0";
  br ^exit;
^exit:
  ret %?x;
}

// EXPECT: PASS
// SOLVER_ARGS: --main @main --path '^entry'
// INTERP_ARGS: --main @main --sym %?off=2
// COMPILER_ARGS: --main @main --sym %?off=2
// SKIP: SOLVER

// Find an offset into an array such that the load yields a specific value.
// Solver SKIP: requires the full spec §9.4 array-theory pointer model
// (addr of array elements + pointer arithmetic). The current solver supports
// only whole-local addr/load/store via BV64 tag dispatch.
fun @main() : i32 {
  sym %?off : index i32 in [0, 3];
  let mut %arr: [4] i32 = {10, 20, 30, 40};
  let mut %p: ptr i32 = null;
^entry:
  %p = addr %arr[0];
  %p = %p + %?off;
  require load %p == 30, "the slot must contain 30";
  ret %?off;
}

// EXPECT: FAIL:UndefinedBehavior
// SKIP: INTERPRETER, COMPILER
// SOLVER_ARGS: --main @main --path '^entry'
//
// Intention: Expose solver missing FP overflow check on vector operations.
// Exposes: Solver bug where fp.isInfinite checks are missing for vector FP operations.
// Expected Behavior: Solver detects that multiplying vector float lanes to infinity triggers UB, making path infeasible (UNSAT).
// Actual Behavior: Solver allows it, returning SAT.

fun @main() : i32 {
  let mut %v1: <4> f32 = {2.0e38, 0.0, 0.0, 0.0};
  let mut %v2: <4> f32 = {2.0, 0.0, 0.0, 0.0};
  let mut %res: <4> f32 = {0.0, 0.0, 0.0, 0.0};
^entry:
  %res = %v1 * %v2; // overflows to inf, should be UNSAT
  ret 0;
}

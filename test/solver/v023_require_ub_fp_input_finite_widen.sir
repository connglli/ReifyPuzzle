// EXPECT: FAIL:UndefinedBehavior
// SOLVER_ARGS: --main @m --path ^entry --require-ub
// SKIP: COMPILER, INTERPRETER
// Widening `%p as f64` is exact and finite for every finite f32 %p, so the
// cast finiteness guards are only violable by a non-finite input. Inputs must
// be finite, so --require-ub is UNSAT on this path. Pre-fix the solver chose
// %p=nan.
fun @m(%p: f32) : f64 {
  let mut %v: f64 = 0.0;
^entry:
  %v = %p as f64;
  ret %v;
}

// EXPECT: PASS
// SOLVER_ARGS: --main @main --path '^entry'
// INTERP_ARGS: --main @main --sym %?v=44
// COMPILER_ARGS: --main @main --sym %?v=44

// Store through a ptr-ptr chain. The inner local must end up == %?v.
fun @main() : i32 {
  sym %?v : value i32 in [0, 100];
  let mut %x: i32 = 0;
  let mut %p: ptr i32 = null;
  let mut %pp: ptr ptr i32 = null;
  let mut %inner: ptr i32 = null;
^entry:
  %p = addr %x;
  %pp = addr %p;
  %inner = load %pp;
  store %inner, %?v;
  require %x == 44, "x must equal v == 44";
  ret 0;
}

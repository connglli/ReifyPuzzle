// EXPECT: FAIL:UndefinedBehavior
// SOLVER_ARGS: --main @main --path '^entry'
// [v0.2.2] Regression: reading an uninitialised aggregate cell is UB (SPEC
// rule 3). The solver's `load` used to force its result `is_defined = true`,
// so it would happily concretize a path that loads `%a[0]` (undef) and uses
// the value — a path the strict interpreter rejects, yielding a solver/interp
// divergence. The fix propagates the loaded cell's definedness through the
// load mux; using the undef value then makes the path UNSAT.
fun @main() : i32 {
  let mut %a: [2] i32 = {undef, undef};
  let mut %p: ptr i32 = undef;
  let mut %r: i32 = 0;
^entry:
  %p = addr %a[0];
  %r = load %p;
  ret %r;
}

// EXPECT: FAIL:UndefinedBehavior
// SKIP: INTERPRETER, COMPILER
// SOLVER_ARGS: --main @main --path '^entry'
//
// Rule 3: solver must detect that load through pointer to undef array
// element is UB, making the path infeasible (UNSAT).
// %a0[0] is undef (ptr i8). addr %a0[0] gives a valid pointer. load
// through that pointer reads undef → UB → path should be UNSAT.
fun @main() : i32 {
  let mut %a0: [1] ptr i8 = {undef};
  let mut %v0: i8 = 42;
  let mut %pp: ptr ptr i8 = undef;
^entry:
  %pp = addr %a0[0];
  store %pp, load %pp;
  ret 0;
}

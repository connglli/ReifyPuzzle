// EXPECT: FAIL:LexError
// Intention: Lexer error: bad exponent format in float vector literal in basic block l1_body

fun @main() : i32 {

  let mut %loop_idx: i32 = 0;
  let mut %loop_idx2: i32 = 0;
  let %two: i32 = 2;
  let mut %v_val: <4> i32 = {1, 2, 3, 4};
  let mut %f_val: <4> f32 = {1.0, 2.0, 3.0, 4.0};
  let mut %cond: i1 = 0;
  let mut %cond2: i1 = 0;
  let %one_i32: i32 = 1;
  let %two_i32: i32 = 2;
  let %three_i32: i32 = 3;
  let %four_i32: i32 = 4;
  let %zero_i32: i32 = 0;
  let %one_f32: f32 = 1.0;
  let %two_f32: f32 = 2.0;
  let %three_f32: f32 = 3.0;
  let %four_f32: f32 = 4.0;
  let %zero_f32: f32 = 0.0;
  let mut %x: <4> f32 = 0.0;

^entry:
  %x[0] = 1.0;
  %f_val[0] = 1.0;
  %f_val[1] = 2.0;
  br ^l1_cond;

^l1_cond:
  %cond = cmp < %loop_idx, %two;
  %cond2 = cmp < %loop_idx2, %two;
  %f_val[2] = 3.0;
  br %cond != 0, ^l1_body, ^mid1;

^l1_body:
  %x = {1.0e+, 2.0, 3.0, 4.0};  // Lexer error: malformed float exp
  %f_val[3] = 4.0;
  %f_val[0] = 5.0;
  br ^l1_latch;

^l1_latch:
  %loop_idx = %loop_idx + 1;
  %f_val[1] = 6.0;
  %f_val[2] = 7.0;
  br ^l1_cond;

^mid1:
  %f_val[3] = 8.0;
  %f_val[0] = 9.0;
  %f_val[1] = 10.0;
  br ^mid2;

^mid2:
  %f_val[2] = 11.0;
  %f_val[3] = 12.0;
  %f_val[0] = 13.0;
  br ^l2_cond;

^l2_cond:
  %cond2 = cmp < %loop_idx2, %two;
  %f_val[1] = 14.0;
  %f_val[2] = 15.0;
  br %cond2 != 0, ^l2_body, ^exit;

^l2_body:
  %x[1] = 2.0;
  %f_val[3] = 16.0;
  %f_val[0] = 17.0;
  br ^l2_latch;

^l2_latch:
  %loop_idx2 = %loop_idx2 + 1;
  %f_val[1] = 18.0;
  %f_val[2] = 19.0;
  br ^l2_cond;

^exit:
  %f_val[3] = 20.0;
  %f_val[0] = 21.0;
  %f_val[1] = 22.0;
  br ^post1;

^post1:
  %f_val[2] = 23.0;
  %f_val[3] = 24.0;
  %f_val[0] = 25.0;
  ret 0;
}

// EXPECT: PASS
// SKIP: INTERPRETER pure compile coverage of widening-mask
// SKIP: SOLVER pure compile coverage of widening-mask
// SPEC v0.2.2 §11.5
// Intention: widening-mask lowering for @popcount at uncommon width i7.

intrinsic @popcount(%x: i7) : i7;

fun @main() : i32 {
  let %x: i7 = 1;
  let mut %r: i7 = 0;
^entry:
  %r = call @popcount(%x);
  ret %r as i32;
}

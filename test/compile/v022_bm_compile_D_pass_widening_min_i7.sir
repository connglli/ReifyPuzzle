// EXPECT: PASS
// SKIP: INTERPRETER pure compile coverage of widening-mask
// SKIP: SOLVER pure compile coverage of widening-mask
// SPEC v0.2.2 §11.5
// Intention: widening-mask lowering for @min at uncommon width i7.

intrinsic @min(%a: i7, %b: i7) : i7;

fun @main() : i32 {
  let %a: i7 = 1;
  let %b: i7 = 0;
  let mut %r: i7 = 0;
^entry:
  %r = call @min(%a, %b);
  ret %r as i32;
}

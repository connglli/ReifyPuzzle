// EXPECT: PASS
// SKIP: SOLVER
// Test: inline CmpAtom mask (cmp >=) with result used in further arithmetic.
fun @main() : i32 {
  let mut %a: <4> i32 = {10, 5, 10, 5};
  let mut %b: <4> i32 = {5, 10, 10, 5};
  let mut %hi: <4> i32 = {1, 1, 1, 1};
  let mut %lo: <4> i32 = {0, 0, 0, 0};
  let mut %res: <4> i32 = {0, 0, 0, 0};
  let mut %sum: i32 = 0;
^entry:
  // mask = (a >= b): lanes 0, 2, 3 are true.
  %res = select cmp >= %a, %b, %hi, %lo;
  // sum = res[0]+res[1]+res[2]+res[3] = 1+0+1+1 = 3
  %sum = %res[0] + %res[1] + %res[2] + %res[3];
  require %sum == 3, "sum of mask bits";
  ret %sum;
}

// EXPECT: PASS
// COMPILER_ARGS: --sym %?a=5,5,5,5 --sym %?b=3,3,3,3
// SKIP: INTERPRETER
// SKIP: SOLVER
// Test: two vector symbols used together in arithmetic.
fun @main(): i32 {
    sym %?a : value <4> i32;
    sym %?b : value <4> i32;
    let mut %wa: <4> i32 = %?a;
    let mut %wb: <4> i32 = %?b;
    let mut %res: <4> i32 = 0;
^entry:
    %res = %wa - %wb;
    require %res[0] == 2, "5-3";
    require %res[1] == 2, "5-3";
    require %res[2] == 2, "5-3";
    require %res[3] == 2, "5-3";
    ret 0;
}

// EXPECT: PASS
// SKIP: INTERPRETER pure compile coverage of widening-mask
// SKIP: SOLVER pure compile coverage of widening-mask
// SPEC v0.2.2 §11.5
// Intention: widening-mask lowering for @clz at uncommon width i17.

intrinsic @clz(%x: i17) : i17;

fun @main() : i32 {
  let %x: i17 = 1;
  let mut %r: i17 = 0;
^entry:
  %r = call @clz(%x);
  ret %r as i32;
}

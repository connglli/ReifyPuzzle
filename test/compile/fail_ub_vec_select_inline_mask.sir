// SKIP: INTERPRETER
// SKIP: SOLVER
// SKIP: WASM
// Reason: WASM doesn't support ASan/UBSan style runtime trapping for vector select mask failures.
//
// Tests: vector select with an inline comparison mask (CmpAtom).
// The C backend expands the mask per-lane inline instead of requiring a
// pre-materialised vector local (RValueAtom).

fun @main() : i32 {
  let mut %v1: <4> i32 = {10, 20, 30, 40};
  let mut %v2: <4> i32 = {50, 60, 70, 80};
  let mut %res: <4> i32 = {0, 0, 0, 0};
^entry:
  %res = select cmp < %v1, %v2, %v1, %v2;
  ret 0;
}

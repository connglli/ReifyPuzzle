// SKIP: SOLVER pure compile coverage of widening-mask
// SPEC v0.2.2 §11.5
// Intention: widening-mask lowering for @abs at uncommon width i9.

intrinsic @abs(%x: i9) : i9;

fun @main() : i32 {
  let %x: i9 = 1;
  let mut %r: i9 = 0;
^entry:
  %r = call @abs(%x);
  ret %r as i32;
}

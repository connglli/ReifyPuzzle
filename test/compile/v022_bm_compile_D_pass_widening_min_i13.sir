// SKIP: SOLVER pure compile coverage of widening-mask
// SPEC v0.2.2 §11.5
// Intention: widening-mask lowering for @min at uncommon width i13.

intrinsic @min(%a: i13, %b: i13) : i13;

fun @main() : i32 {
  let %a: i13 = 1;
  let %b: i13 = 0;
  let mut %r: i13 = 0;
^entry:
  %r = call @min(%a, %b);
  ret %r as i32;
}

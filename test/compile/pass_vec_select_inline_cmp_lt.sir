// EXPECT: PASS
// SKIP: SOLVER
// Test: inline CmpAtom mask (cmp <) in a mask-form vector select should compile and run.
fun @main() : i32 {
  let mut %v1: <4> i32 = {1, 5, 3, 7};
  let mut %v2: <4> i32 = {4, 2, 6, 0};
  let mut %res: <4> i32 = {0, 0, 0, 0};
^entry:
  // select lanes where v1 < v2: lanes 0 and 2 → take v1, else take v2.
  %res = select cmp < %v1, %v2, %v1, %v2;
  // lane 0: 1 < 4  → v1[0]=1
  // lane 1: 5 < 2  → v2[1]=2
  // lane 2: 3 < 6  → v1[2]=3
  // lane 3: 7 < 0  → v2[3]=0
  require %res[0] == 1, "lane 0";
  require %res[1] == 2, "lane 1";
  require %res[2] == 3, "lane 2";
  require %res[3] == 0, "lane 3";
  ret 0;
}

// EXPECT: PASS
// COMPILER_ARGS: -I test/lib/std/scalar -I test/lib/std/collections
// Rationale: [v0.2.2] §9.6.1, §10.7, §11.2 - Compiler support for interprocedural calls and -I resolution.
// Covers internal fun, external decl (link-form), structs, pointers, floats, vectors, arrays.
// Each block has at least 3 non-trivial instructions and a conditional terminator.

struct @Point {
  x: f32;
  y: f32;
}

decl @gcd(%a: i32, %b: i32) : i32;
decl @array_sum_4_i32(%p: ptr [4] i32) : i32;

fun @compute_dist_sq(%p1: ptr @Point, %p2: ptr @Point) : f32 {
  let mut %x1: f32 = 0.0;
  let mut %y1: f32 = 0.0;
  let mut %x2: f32 = 0.0;
  let mut %y2: f32 = 0.0;
  let mut %dx: f32 = 0.0;
  let mut %dy: f32 = 0.0;
  let mut %dx2: f32 = 0.0;
  let mut %dy2: f32 = 0.0;
  let mut %sum: f32 = 0.0;
  let mut %p_ptr: ptr f32 = null;
^entry:
  %p_ptr = ptrfield %p1, x; %x1 = load %p_ptr;
  %p_ptr = ptrfield %p1, y; %y1 = load %p_ptr;
  %p_ptr = ptrfield %p2, x; %x2 = load %p_ptr;
  %p_ptr = ptrfield %p2, y; %y2 = load %p_ptr;
  %dx = %x1 - %x2;
  %dy = %y1 - %y2;
  %dx2 = %dx * %dx;
  %dy2 = %dy * %dy;
  %sum = %dx2 + %dy2;
  ret %sum;
}

fun @main() : i32 {
  let mut %pt1: @Point = { 10.0, 20.0 };
  let mut %pt2: @Point = { 13.0, 24.0 };
  let mut %arr: [4] i32 = { 1, 2, 3, 4 };
  let mut %d2: f32 = 0.0;
  let mut %a: i32 = 48;
  let mut %b: i32 = 18;
  let mut %g: i32 = 0;
  let mut %s: i32 = 0;
  let mut %v: <4> i32 = { 1, 1, 1, 1 };
  let mut %res: i32 = 0;
  let %zero: i32 = 0;
  let %one: i32 = 1;
  let %target_g: i32 = 6;
  let %target_s: i32 = 10;
  let %target_d2: f32 = 25.0;
^entry:
  %g = call @gcd(%a, %b);
  %d2 = call @compute_dist_sq(addr %pt1, addr %pt2);
  %s = call @array_sum_4_i32(addr %arr);
  %v[0] = %g;
  %v[1] = %one;
  br %g == %target_g, ^check_dist, ^fail;

^check_dist:
  %v[2] = %one;
  %v[3] = %one;
  %res = %g + %one;
  br %d2 == %target_d2, ^check_sum, ^fail;

^check_sum:
  %res = %s + %one;
  %res = %res - %one;
  %res = %res * %one;
  br %s == %target_s, ^vector_op, ^fail;

^vector_op:
  %res = %v[0] + %v[1];
  %res = %res + %v[2];
  %res = %res + %v[3];
  br %res == 9, ^exit, ^fail;

^fail:
  %res = %res * %one;
  %res = %res + %zero;
  %res = %res / %one;
  br %zero == %zero, ^fail_exit, ^fail_exit;

^fail_exit:
  %res = %res + %one;
  %res = %res - %one;
  %res = %res * %one;
  ret %one;

^exit:
  %res = %res * %one;
  %res = %res + %zero;
  %res = %res / %one;
  br %zero == %zero, ^real_exit, ^real_exit;

^real_exit:
  %res = %res + %one;
  %res = %res - %one;
  %res = %res * %one;
  ret %zero;
}

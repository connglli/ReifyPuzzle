// EXPECT: PASS
// COMPILER_ARGS: --sym %?fsym=3.14
// INTERP_ARGS: --sym %?fsym=3.14

fun @main() : i32 {
  sym %?fsym: value f32;
  let mut %mem_f32: f32 = 0.0;
  let mut %mem_f64: f64 = 0.0;
  let mut %ptr_f32: ptr f32 = null;
  let mut %ptr_f64: ptr f64 = null;

  let mut %val1: f32 = 0.0;
  let mut %val2: f64 = 0.0;

  let mut %c1: i32 = 0;
  let mut %c2: i32 = 0;
  let mut %c3: i32 = 0;
  let mut %c4: i32 = 0;

  let mut %ret_val: i32 = 0;

^entry:
  %ptr_f32 = addr %mem_f32;
  %ptr_f64 = addr %mem_f64;
  store %ptr_f32, 1.5;
  store %ptr_f64, 2.5;

  %val1 = load %ptr_f32;
  %val2 = load %ptr_f64;

  %c1 = %val1 as i32;
  %c2 = %val2 as i32;
  %c3 = 3.14 as i32;
  %c4 = %?fsym as i32;

  %ret_val = %c1 + %c2;
  %ret_val = %ret_val + %c3;
  %ret_val = %ret_val + %c4;

  ret %ret_val;
}

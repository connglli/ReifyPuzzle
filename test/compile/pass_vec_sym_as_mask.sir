// EXPECT: PASS
// COMPILER_ARGS: --sym %?v=0,1,0,1
// SKIP: INTERPRETER
// SKIP: SOLVER
// Test: vector symbol init, then use as mask source in a select.
fun @main(): i32 {
    sym %?v : value <4> i32;
    let mut %mask: <4> i32 = %?v;
    let mut %zero: <4> i32 = {0, 0, 0, 0};
    let mut %yes: <4> i32 = {10, 10, 10, 10};
    let mut %no:  <4> i32 = {-1, -1, -1, -1};
    let mut %res: <4> i32 = {0, 0, 0, 0};
^entry:
    %res = select cmp != %mask, %zero, %yes, %no;
    require %res[0] == -1, "lane0 mask=0";
    require %res[1] == 10, "lane1 mask=1";
    require %res[2] == -1, "lane2 mask=0";
    require %res[3] == 10, "lane3 mask=1";
    ret 0;
}

// EXPECT: PASS
// Step a pointer through an array via `%p + 1`, summing values.
// Returns 100 (= 10+20+30+40).
fun @main() : i32 {
  let mut %arr: [4] i32 = {10, 20, 30, 40};
  let mut %p: ptr i32 = null;
  let mut %acc: i32 = 0;
  let %one: i32 = 1;
^entry:
  %p = addr %arr[0];
  %acc = %acc + load %p;
  %p = %p + %one;
  %acc = %acc + load %p;
  %p = %p + %one;
  %acc = %acc + load %p;
  %p = %p + %one;
  %acc = %acc + load %p;
  ret %acc;
}

// EXPECT: PASS
// COMPILER_ARGS: --target c
// Regression: identical nested array shapes (`[2] [3]`) with different
// `ptr T` leaves must not collide. Shape encoding alone is not enough
// to disambiguate — the leaf must be encoded too.
fun @main(): i32 {
  let mut %a32: [2] [3] ptr i32 = {{undef, undef, undef}, {undef, undef, undef}};
  let mut %a64: [2] [3] ptr i64 = {{undef, undef, undef}, {undef, undef, undef}};
  let mut %p32: ptr [2] [3] ptr i32 = undef;
  let mut %p64: ptr [2] [3] ptr i64 = undef;
^entry:
  %p32 = addr %a32;
  %p64 = addr %a64;
  ret 0;
}

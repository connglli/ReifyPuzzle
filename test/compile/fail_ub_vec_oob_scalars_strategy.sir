// EXPECT: FAIL
// SKIP: INTERPRETER
// COMPILER_ARGS: --vec-lowering scalars

// Testing the 'scalars' strategy with a dynamic (runtime) lane index.
// Every backend's 'scalars' lowering rejects dynamic indices at
// emission time — a runtime index cannot select a distinct variable —
// so this fails at compile time on C, WASM, and python alike.
// (Rule 20 OOB would apply had it compiled.)

fun @main() : i32 {
  let mut %v: <4> i32 = {1, 2, 3, 4};
  let mut %res: i32 = 0;
  let mut %idx: i32 = 4; // OOB
^entry:
  %res = %v[%idx];
  ret %res;
}

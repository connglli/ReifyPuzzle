// EXPECT: PASS
// COMPILER_ARGS: --target c
// Regression: three distinct `ptr T` leaves (i8, i32, f32) under the
// same `[N]` shape must produce three distinct typedef names.
fun @main(): i32 {
  let mut %a8:  [2] ptr i8  = {undef, undef};
  let mut %a32: [2] ptr i32 = {undef, undef};
  let mut %af:  [2] ptr f32 = {undef, undef};
  let mut %p8:  ptr [2] ptr i8  = undef;
  let mut %p32: ptr [2] ptr i32 = undef;
  let mut %pf:  ptr [2] ptr f32 = undef;
^entry:
  %p8  = addr %a8;
  %p32 = addr %a32;
  %pf  = addr %af;
  ret 0;
}

// EXPECT: PASS
// SKIP: SOLVER
// Test: inline CmpAtom mask on f32 vector elements (cmp >).
fun @main() : i32 {
  let mut %a: <4> f32 = {3.0, 1.0, 4.0, 1.0};
  let mut %b: <4> f32 = {1.5, 2.0, 2.0, 5.0};
  let mut %hi: <4> i32 = {1, 1, 1, 1};
  let mut %lo: <4> i32 = {0, 0, 0, 0};
  let mut %res: <4> i32 = {0, 0, 0, 0};
^entry:
  // mask = (a > b): lanes 0 and 2 are true (3>1.5, 4>2).
  %res = select cmp > %a, %b, %hi, %lo;
  require %res[0] == 1, "lane0 3.0>1.5";
  require %res[1] == 0, "lane1 1.0<2.0";
  require %res[2] == 1, "lane2 4.0>2.0";
  require %res[3] == 0, "lane3 1.0<5.0";
  ret 0;
}

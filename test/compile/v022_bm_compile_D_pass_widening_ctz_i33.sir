// Intention: widening-mask lowering for @ctz at uncommon width i33.

intrinsic @ctz(%x: i33) : i33;

fun @main() : i32 {
  let %x: i33 = 1;
  let mut %r: i33 = 0;
^entry:
  %r = call @ctz(%x);
  ret %r as i32;
}

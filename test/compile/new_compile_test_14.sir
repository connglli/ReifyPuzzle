// COMPILER_ARGS:
// EXPECT: PASS
// Intention: Fibonacci with aggregate array pointers and subtraction

fun @main() : i32 {

  let mut %loop_idx: i32 = 0;
  let %two: i32 = 2;
  let mut %v_val: <4> i32 = {1, 2, 3, 4};
  let mut %f_val: <4> f32 = {1.0, 2.0, 3.0, 4.0};
  let mut %cond: i1 = 0;
  let mut %cond2: i1 = 0;
  let mut %pre_cond: i1 = 0;
  let mut %post_cond: i1 = 0;
  let %one_i32: i32 = 1;
  let %two_i32: i32 = 2;
  let %three_i32: i32 = 3;
  let %four_i32: i32 = 4;
  let %zero_i32: i32 = 0;
  let %one_f32: f32 = 1.0;
  let %two_f32: f32 = 2.0;
  let %three_f32: f32 = 3.0;
  let %four_f32: f32 = 4.0;
  let %zero_f32: f32 = 0.0;
  let mut %arr: [8] i32 = {0, 0, 0, 0, 0, 0, 0, 0};
  let mut %p_start: ptr i32 = null;
  let mut %p_end: ptr i32 = null;
  let mut %dist: i64 = 0;
  let mut %fib: <4> i32 = {0, 1, 1, 2};

^entry:
  %pre_cond = cmp < %one_i32, %two_i32;
  %post_cond = cmp < %two_i32, %one_i32;
  %p_start = addr %arr[0];
  %p_end = addr %arr[3];
  %v_val = 1 * %fib;
  br %pre_cond != 0, ^pre_left, ^pre_right;

^pre_left:
  %dist = %p_end - %p_start;
  %v_val[0] = 1;
  %v_val = 1 * %fib;
  br ^pre_merge;

^pre_right:
  %dist = %p_start - %p_end;
  %v_val[1] = 2;
  %v_val = 1 * %fib;
  br ^pre_merge;

^pre_merge:
  %v_val = %fib;
  %v_val[2] = 3;
  %v_val = 1 * %fib;
  br ^loop_cond;

^loop_cond:
  %cond = cmp < %loop_idx, %two;
  %fib[0] = %fib[1];
  %v_val = 1 * %fib;
  br %cond != 0, ^body1, ^post_split;

^body1:
  %fib[1] = %fib[2];
  %v_val[3] = 4;
  %v_val = 1 * %fib;
  br ^body2;

^body2:
  %v_val = %fib;
  %v_val[0] = 5;
  %v_val = 1 * %fib;
  br ^latch;

^latch:
  %loop_idx = %loop_idx + 1;
  %v_val[1] = 6;
  %v_val = 1 * %fib;
  br ^loop_cond;

^post_split:
  %v_val = %fib;
  %v_val[2] = 7;
  %v_val = 1 * %fib;
  br %post_cond != 0, ^post_left, ^post_right;

^post_left:
  %v_val[3] = 8;
  %v_val = %fib;
  %v_val = 1 * %fib;
  br ^exit;

^post_right:
  %v_val[3] = 9;
  %v_val = %fib;
  %v_val = 1 * %fib;
  br ^exit;

^exit:
  require %dist == 3;
  require %fib[0] > 0;
  %v_val = 1 * %fib;
  ret 0;
}

// SKIP: INTERPRETER pure compile coverage of widening-mask
// SKIP: SOLVER pure compile coverage of widening-mask
// SPEC v0.2.2 §11.5
// Intention: widening-mask lowering for @max at uncommon width i17.

intrinsic @max(%a: i17, %b: i17) : i17;

fun @main() : i32 {
  let %a: i17 = 1;
  let %b: i17 = 0;
  let mut %r: i17 = 0;
^entry:
  %r = call @max(%a, %b);
  ret %r as i32;
}

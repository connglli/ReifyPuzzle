// EXPECT: PASS
// SKIP: SOLVER
// Test: inline CmpAtom mask (cmp ==) in a mask-form vector select.
fun @main() : i32 {
  let mut %v1: <4> i32 = {1, 2, 3, 4};
  let mut %v2: <4> i32 = {1, 9, 9, 4};
  let mut %yes: <4> i32 = {100, 100, 100, 100};
  let mut %no:  <4> i32 = {0, 0, 0, 0};
  let mut %res: <4> i32 = {0, 0, 0, 0};
^entry:
  // mask = (v1 == v2): lanes 0 and 3 match.
  %res = select cmp == %v1, %v2, %yes, %no;
  require %res[0] == 100, "lane 0 equal";
  require %res[1] == 0,   "lane 1 unequal";
  require %res[2] == 0,   "lane 2 unequal";
  require %res[3] == 100, "lane 3 equal";
  ret 0;
}

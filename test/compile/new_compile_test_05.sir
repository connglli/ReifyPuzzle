// COMPILER_ARGS:
struct @Complex { r: f32; i: f32; }
// EXPECT: PASS
// Intention: Vector Mandelbrot with Complex Struct Pointer

fun @main() : i32 {

  let mut %loop_idx: i32 = 0;
  let mut %loop_idx2: i32 = 0;
  let %two: i32 = 2;
  let mut %v_val: <4> i32 = {1, 2, 3, 4};
  let mut %f_val: <4> f32 = {1.0, 2.0, 3.0, 4.0};
  let mut %cond: i1 = 0;
  let mut %cond2: i1 = 0;
  let %one_i32: i32 = 1;
  let %two_i32: i32 = 2;
  let %three_i32: i32 = 3;
  let %four_i32: i32 = 4;
  let %zero_i32: i32 = 0;
  let %one_f32: f32 = 1.0;
  let %two_f32: f32 = 2.0;
  let %three_f32: f32 = 3.0;
  let %four_f32: f32 = 4.0;
  let %zero_f32: f32 = 0.0;
  let mut %c_val: @Complex = { -0.7, 0.27 };
  let mut %p_r: ptr f32 = null;
  let mut %p_i: ptr f32 = null;
  let mut %zr: <4> f32 = {0.0, 0.0, 0.0, 0.0};
  let mut %zi: <4> f32 = {0.0, 0.0, 0.0, 0.0};
  let mut %zr2: <4> f32 = {0.0, 0.0, 0.0, 0.0};
  let mut %zi2: <4> f32 = {0.0, 0.0, 0.0, 0.0};
  let %two_f: <4> f32 = {2.0, 2.0, 2.0, 2.0};
  let mut %r_val: f32 = 0.0;
  let mut %i_val: f32 = 0.0;

^entry:
  %p_r = addr %c_val.r;
  %p_i = addr %c_val.i;
  %zr = %zr + 0.1;
  br ^l1_cond;

^l1_cond:
  %cond = cmp < %loop_idx, %two;
  %cond2 = cmp < %loop_idx2, %two;
  %f_val = 1.0 * %zr;
  br %cond != 0, ^l1_body, ^mid1;

^l1_body:
  %r_val = load %p_r;
  %i_val = load %p_i;
  %zr[0] = %r_val; %zi[0] = %i_val; %f_val = 1.0 * %zr;
  br ^l1_latch;

^l1_latch:
  %loop_idx = %loop_idx + %one_i32;
  %f_val[1] = 2.0;
  %f_val = 1.0 * %zr;
  br ^l1_cond;

^mid1:
  %f_val = %zr;
  %f_val[2] = 3.0;
  %f_val = 1.0 * %zr;
  br ^mid2;

^mid2:
  %f_val = %zi;
  %f_val[3] = 4.0;
  %f_val = 1.0 * %zr;
  br ^l2_cond;

^l2_cond:
  %cond2 = cmp < %loop_idx2, %two;
  %f_val[0] = 5.0;
  %f_val = 1.0 * %zr;
  br %cond2 != 0, ^l2_body, ^exit;

^l2_body:
  %zr2 = %zr * %zr;
  %zi2 = %zi * %zi;
  %zr = %zr2 - %zi2;
  br ^l2_latch;

^l2_latch:
  %loop_idx2 = %loop_idx2 + %one_i32;
  %f_val[1] = 6.0;
  %f_val = 1.0 * %zr;
  br ^l2_cond;

^exit:
  require %zr[0] > -10.0;
  require %zi[0] < 2.0;
  %f_val = 1.0 * %f_val;
  br ^post1;

^post1:
  %f_val = %zr;
  %f_val[2] = 7.0;
  %f_val = 1.0 * %zr;
  ret 0;
}

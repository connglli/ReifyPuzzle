{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "RefractIR",
  "scopeName": "source.refractir",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#literals"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.refractir",
          "match": "//.*"
        },
        {
          "name": "comment.block.refractir",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.refractir",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.refractir",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "comment": "Control-flow terminators",
          "name": "keyword.control.refractir",
          "match": "\\b(br|ret|unreachable)\\b"
        },
        {
          "comment": "Function calls",
          "name": "keyword.control.refractir",
          "match": "\\bcall\\b"
        },
        {
          "comment": "Path assertions / assumptions",
          "name": "keyword.control.assertion.refractir",
          "match": "\\b(assume|require)\\b"
        },
        {
          "comment": "Memory and pointer operations",
          "name": "keyword.other.memory.refractir",
          "match": "\\b(addr|load|store|ptrindex|ptrfield)\\b"
        },
        {
          "comment": "Expression-keyword operators",
          "name": "keyword.other.expression.refractir",
          "match": "\\b(select|cmp|as)\\b"
        },
        {
          "comment": "Declaration keywords",
          "name": "keyword.other.declaration.refractir",
          "match": "\\b(struct|fun|sym|let|mut|value|coef|index|in|decl|intrinsic)\\b"
        },
        {
          "comment": "Contract clause keywords",
          "name": "keyword.other.contract.refractir",
          "match": "\\b(pre|post)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "comment": "Pointer type constructor",
          "name": "support.type.pointer.refractir",
          "match": "\\bptr\\b"
        },
        {
          "comment": "Integer types: i8, i16, i32, i64, iN",
          "name": "support.type.integer.refractir",
          "match": "\\bi[0-9]+\\b"
        },
        {
          "comment": "Floating-point types",
          "name": "support.type.float.refractir",
          "match": "\\b(f32|f64)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "comment": "Null pointer constant",
          "name": "constant.language.null.refractir",
          "match": "\\bnull\\b"
        },
        {
          "comment": "Uninitialized value sentinel",
          "name": "constant.language.undef.refractir",
          "match": "\\bundef\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "comment": "Global identifier: @name",
          "name": "entity.name.function.refractir",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "comment": "Local identifier: %name",
          "name": "variable.other.local.refractir",
          "match": "%[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "comment": "Block label: ^name",
          "name": "entity.name.label.refractir",
          "match": "\\^[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.numeric.hex.refractir",
          "match": "-?0x[0-9a-fA-F]+"
        },
        {
          "name": "constant.numeric.octal.refractir",
          "match": "-?0o[0-7]+"
        },
        {
          "name": "constant.numeric.binary.refractir",
          "match": "-?0b[01]+"
        },
        {
          "name": "constant.numeric.float.refractir",
          "match": "-?[0-9]+\\.[0-9]+([eE][-+]?[0-9]+)?"
        },
        {
          "name": "constant.numeric.decimal.refractir",
          "match": "-?[0-9]+"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.refractir",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.bitwise.refractir",
          "match": ">>>|>>|<<|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.arithmetic.refractir",
          "match": "\\+|\\-|\\*|/|%"
        },
        {
          "name": "keyword.operator.assignment.refractir",
          "match": "="
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.refractir",
          "match": ";"
        },
        {
          "name": "punctuation.separator.refractir",
          "match": ",|:"
        },
        {
          "name": "punctuation.accessor.refractir",
          "match": "\\."
        },
        {
          "name": "punctuation.section.block.begin.refractir",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.refractir",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.begin.refractir",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.refractir",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.parens.begin.refractir",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.refractir",
          "match": "\\)"
        }
      ]
    }
  }
}

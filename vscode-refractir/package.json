{
    "name": "refractir-syntax",
    "repository": {
        "type": "git",
        "url": "https://github.com/connglli/refractir"
    },
    "displayName": "RefractIR Syntax Highlighting",
    "description": "Syntax highlighting for RefractIR (.sir) files",
    "version": "0.2.2",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "refractir",
                "aliases": [
                    "RefractIR",
                    "refractir"
                ],
                "extensions": [
                    ".sir"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "refractir",
                "scopeName": "source.refractir",
                "path": "./syntaxes/refractir.tmLanguage.json"
            }
        ]
    }
}
